---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EntryCard from '../../../components/EntryCard.astro';
import AutoLinkNames from '../../../components/AutoLinkNames.astro';
import { render } from 'astro:content';
import { useTranslations, getEntries, getBiographyForParticipant, localePath, translateParticipantName, absoluteUrl } from '../../../i18n/utils';
import { buildThreadInfo, collapseThreads, resolveThreadId } from '../../../data/threads';

export async function getStaticPaths() {
  const { getEntries, getDisplayEntries } = await import('../../../i18n/utils');
  const entries = await getEntries('ja');
  const displayEntries = await getDisplayEntries('en');
  const slugs = new Set<string>();
  const nameMap = new Map<string, string>();
  for (const entry of entries) {
    for (const p of entry.data.participants) {
      slugs.add(p.slug);
      nameMap.set(p.slug, p.name);
    }
  }
  const countMap = new Map<string, number>();
  for (const entry of displayEntries) {
    for (const p of entry.data.participants) {
      countMap.set(p.slug, (countMap.get(p.slug) || 0) + 1);
    }
  }
  // 英語側に存在する参加者 slug を取得
  const enEntries = await getEntries('en');
  const enSlugs = new Set<string>();
  for (const entry of enEntries) {
    for (const p of entry.data.participants) {
      enSlugs.add(p.slug);
    }
  }

  const sorted = Array.from(slugs).sort((a, b) => (countMap.get(b) || 0) - (countMap.get(a) || 0));
  return sorted.map((slug, i) => ({
    params: { participant: slug },
    props: {
      participantSlug: slug,
      participantName: translateParticipantName(nameMap.get(slug)!, slug, 'ja'),
      prevParticipant: i > 0 ? { slug: sorted[i - 1], name: translateParticipantName(nameMap.get(sorted[i - 1])!, sorted[i - 1], 'ja') } : null,
      nextParticipant: i < sorted.length - 1 ? { slug: sorted[i + 1], name: translateParticipantName(nameMap.get(sorted[i + 1])!, sorted[i + 1], 'ja') } : null,
      hasEn: enSlugs.has(slug),
    },
  }));
}

const lang = 'ja';
const t = useTranslations(lang);
const { participantSlug, participantName, prevParticipant, nextParticipant, hasEn } = Astro.props;
const entries = await getEntries(lang);
const filtered = entries.filter((e) =>
  e.data.participants.some((p) => p.slug === participantSlug)
);

const allEntries = await getEntries(lang);
const { threadCounts, threadStarters, threadTitles } = buildThreadInfo(allEntries, lang);
const biographyEntry = await getBiographyForParticipant(lang, participantSlug);
const biographyContent = biographyEntry ? await render(biographyEntry) : null;
const hypothesisEntry = filtered.find((e) =>
  e.data.type === 'analysis' &&
  e.id.includes('-satoshi-identity-hypothesis') &&
  e.data.participants[0]?.slug === participantSlug
);
const nonBio = filtered.filter((e) => e.data.type !== 'biography');
const displayEntries = collapseThreads(nonBio, threadCounts, threadStarters);
const lifeDatesMatch = biographyEntry?.data.title.match(/[（(]([^)）]+)[)）]/);
const lifeDatesRaw = lifeDatesMatch ? lifeDatesMatch[0] : null;
const lifeDates = lifeDatesRaw && !/生没年不明|dates unknown/.test(lifeDatesRaw) ? lifeDatesRaw : null;
const biographyDescription = biographyEntry?.data.description?.replace(/^[^：:]+[：:]\s*/, '') ?? '';
const canonicalUrl = absoluteUrl(`/participants/${participantSlug}/`, lang);
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "ProfilePage",
    "name": `${participantName} - ${t('site.title')}`,
    "url": canonicalUrl,
    "inLanguage": lang,
    "mainEntity": {
      "@id": `${canonicalUrl}#person`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": `${canonicalUrl}#person`,
    "name": participantName,
    ...(biographyDescription ? { "description": biographyDescription } : {}),
    "url": canonicalUrl,
    "subjectOf": {
      "@type": "ItemList",
      "name": `${participantName}に関するエントリー`,
      "numberOfItems": displayEntries.length,
    },
  },
];
---

<BaseLayout
  title={`${participantName}${biographyEntry?.data.title.match(/—\s*(.+)/)?.[1] ? ` — ${biographyEntry.data.title.match(/—\s*(.+)/)[1]}` : ''} - ${t('site.title')}`}
  description={biographyEntry?.data.description ?? `${participantName}のビットコイン初期における投稿・メール・技術的議論のアーカイブ`}
  lang={lang}
  alternateEn={hasEn ? absoluteUrl(`/participants/${participantSlug}/`, 'en') : undefined}
  structuredData={structuredData}
>
  <div class="container">
    <nav class="participant-nav participant-nav-top">
      {prevParticipant ? (
        <a href={localePath(`/participants/${prevParticipant.slug}/`, lang)} class="nav-prev">&larr; {prevParticipant.name}</a>
      ) : <span />}
      {nextParticipant ? (
        <a href={localePath(`/participants/${nextParticipant.slug}/`, lang)} class="nav-next">{nextParticipant.name} &rarr;</a>
      ) : <span />}
    </nav>
    <h1>{participantName}{lifeDates && <span class="life-dates"> {lifeDates}</span>}</h1>

    {hypothesisEntry && (
      <a class="hypothesis-callout" href={localePath(`/entries/${hypothesisEntry.id}/`, lang)}>
        <span class="hypothesis-icon">🔍</span>
        <span class="hypothesis-label">サトシ正体仮説</span>
        <span class="hypothesis-arrow">&rarr;</span>
      </a>
    )}

    {biographyContent && (
      <section class="biography-section">
        <div class="biography-content">
          <biographyContent.Content />
        </div>
      </section>
    )}

    {biographyContent ? (
      <h2 class="entries-heading">{t('participant.relatedEntries' as any)}</h2>
    ) : null}
    <p class="entry-count">{displayEntries.length} エントリー</p>
    {displayEntries.map((entry) => {
      const tid = resolveThreadId(entry);
      const msgCount = tid ? threadCounts.get(tid) || 0 : 0;
      const isThread = msgCount >= 2;
      return (
        <EntryCard
          id={entry.id}
          title={isThread ? threadTitles.get(tid!) || entry.data.title : entry.data.title}
          date={entry.data.date}
          author={entry.data.author}
          source={entry.data.source}
          description={entry.data.description}
          isSatoshi={entry.data.isSatoshi}
          lang={lang}
          threadId={isThread ? tid : undefined}
          threadCount={isThread ? msgCount : undefined}
          participants={entry.data.participants}
        />
      );
    })}

    <nav class="participant-nav">
      {prevParticipant ? (
        <a href={localePath(`/participants/${prevParticipant.slug}/`, lang)} class="nav-prev">&larr; {prevParticipant.name}</a>
      ) : <span />}
      {nextParticipant ? (
        <a href={localePath(`/participants/${nextParticipant.slug}/`, lang)} class="nav-next">{nextParticipant.name} &rarr;</a>
      ) : <span />}
    </nav>
  </div>
  {biographyContent && (
    <AutoLinkNames lang={lang} excludeSlug={participantSlug} selectors=".biography-content" />
  )}
</BaseLayout>

<style>
  h1 { margin-bottom: 1rem; }
  .life-dates {
    font-weight: normal;
    font-size: 0.6em;
    color: var(--color-text-muted);
  }
  .hypothesis-callout {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
    padding: 0.4rem 0.9rem;
    background: var(--color-bg-alt);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 3px 3px 0;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    text-decoration: none;
    color: var(--color-link);
  }
  .hypothesis-callout:hover {
    text-decoration: underline;
  }
  .hypothesis-callout .hypothesis-arrow {
    color: var(--color-text-muted);
  }
  .biography-section {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .biography-content {
    line-height: 1.8;
  }
  .biography-content :global(p:first-child) {
    margin-top: 0;
  }
  .entries-heading {
    margin-top: 0;
    margin-bottom: 0.25rem;
  }
  .entry-count {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: 0;
  }
  .participant-nav {
    display: flex;
    justify-content: space-between;
    margin-top: 2.5rem;
    padding-top: 0;
    font-family: var(--font-heading);
    font-size: 0.9rem;
  }
  .participant-nav-top {
    margin-top: 1.5rem;
    padding-top: 0;
    border-top: none;
    margin-bottom: 0.5rem;
  }
  .nav-next {
    margin-left: auto;
  }
</style>
