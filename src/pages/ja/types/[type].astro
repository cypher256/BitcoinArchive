---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EntryCard from '../../../components/EntryCard.astro';
import { useTranslations, getDisplayEntries, absoluteUrl } from '../../../i18n/utils';
import { buildThreadInfo, collapseThreads, resolveThreadId } from '../../../data/threads';
import gitDates from '../../../data/git-dates.json';

type LangDate = { createdAt: string; updatedAt: string };
type GitDateRecord = { en?: LangDate; ja?: LangDate };
const gitDateMap = gitDates as Record<string, GitDateRecord>;
function gitJa(id: string) {
  return gitDateMap[id]?.ja ?? gitDateMap[id]?.en;
}

export async function getStaticPaths() {
  const { getDisplayEntries } = await import('../../../i18n/utils');
  const entries = await getDisplayEntries('ja');
  const types = [...new Set(entries.map((e) => e.data.type))];
  const enEntries = await getDisplayEntries('en');
  const enTypes = new Set(enEntries.map((e) => e.data.type));
  return types.map((type) => ({
    params: { type },
    props: { type, hasEn: enTypes.has(type) },
  }));
}

const lang = 'ja';
const t = useTranslations(lang);
const { type, hasEn } = Astro.props;
const entries = await getDisplayEntries(lang);
const { threadCounts, threadStarters, threadTitles } = buildThreadInfo(entries, lang);
const filtered = entries.filter((e) => e.data.type === type);
// Analysis listings sort by editorial updatedAt (git history); other
// types stay on frontmatter.date descending. See EN mirror
// src/pages/types/[type].astro and temp/0518_一覧並び順と日付表示計画.md.
function entryUpdatedTs(id: string, fallback: Date): number {
  // Fallback chain matches the EN mirror (see comment there).
  const rec = gitJa(id);
  const ts = rec?.updatedAt ?? rec?.createdAt;
  return ts ? new Date(ts).getTime() : fallback.getTime();
}
const isAnalysisType = type === 'analysis';
const displayEntries = isAnalysisType
  ? collapseThreads(filtered, threadCounts, threadStarters)
      .slice()
      .sort((a, b) => entryUpdatedTs(b.id, b.data.date) - entryUpdatedTs(a.id, a.data.date))
  : collapseThreads(filtered, threadCounts, threadStarters).reverse();
const typeLabel = t(`type.${type}` as any) || type;

const pageDescription = `${typeLabel}形式のエントリー。サトシ・ナカモトと初期ビットコイン貢献者によるこの形式の通信を、原典とともにアーカイブから集約。`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `${typeLabel} - ${t('site.title')}`,
  "url": absoluteUrl(`/types/${type}/`, lang),
  "description": pageDescription,
  "inLanguage": lang,
  "mainEntity": {
    "@type": "ItemList",
    "name": typeLabel,
    "numberOfItems": displayEntries.length,
    "itemListOrder": "https://schema.org/ItemListOrderDescending",
    "itemListElement": displayEntries.slice(0, 25).map((entry: any, index: number) => {
      const tid = resolveThreadId(entry);
      const msgCount = tid ? threadCounts.get(tid) || 0 : 0;
      const isThread = msgCount >= 2;
      const itemUrl = isThread
        ? absoluteUrl(`/entries/threads/${tid}/`, lang)
        : absoluteUrl(`/entries/${entry.id}/`, lang);
      const itemName = isThread
        ? (threadTitles.get(tid!) || entry.data.title)
        : entry.data.title;
      return {
        "@type": "ListItem",
        "position": index + 1,
        "url": itemUrl,
        "name": itemName,
      };
    }),
  },
};
---

<BaseLayout
  title={`${typeLabel} - ${t('site.title')}`}
  description={pageDescription}
  lang={lang}
  alternateEn={hasEn ? absoluteUrl(`/types/${type}/`, 'en') : undefined}
  structuredData={structuredData}
>
  <div class="container-wide">
    <h1>{typeLabel}</h1>
    <p class="page-lead">この形式（タイプ）のエントリー集約。形式軸で時間を追うと、ビットコイン黎明期のコミュニケーション様式の変遷が見えます。</p>
    <p class="entry-count">{displayEntries.length} エントリー</p>
    {displayEntries.map((entry) => {
      const tid = resolveThreadId(entry);
      const msgCount = tid ? threadCounts.get(tid) || 0 : 0;
      const isThread = msgCount >= 2;
      return (
        <EntryCard
          id={entry.id}
          title={isThread ? threadTitles.get(tid!) || entry.data.title : entry.data.title}
          date={entry.data.date}
          author={entry.data.author}
          source={entry.data.source}
          description={entry.data.description}
          isSatoshi={entry.data.isSatoshi}
          lang={lang}
          threadId={isThread ? tid : undefined}
          threadCount={isThread ? msgCount : undefined}
          participants={entry.data.participants}
          entryType={entry.data.type}
          createdAt={gitJa(entry.id)?.createdAt}
          updatedAt={gitJa(entry.id)?.updatedAt}
        />
      );
    })}
  </div>
</BaseLayout>

<style>
  h1 { margin-bottom: 0.25rem; }
  .page-lead {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0 0 0.75rem 0;
  }
  .entry-count {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: 0;
  }
</style>
