---
/**
 * RelatedEntries.astro — Renders the "Related entries" section on entry pages.
 *
 * Selection policy (manual-first, cap 10):
 *   1. Start from manual frontmatter.relatedEntries (editor-curated).
 *   2. Append auto-derived candidates from src/data/derived-related.json
 *      (computed by scripts/generate-derived-related.mjs from inline-link
 *      structure) that are not already in the manual list.
 *   3. Slice to 10 items. Manual entries are guaranteed to survive the cap
 *      as long as they are ≤ 10.
 *
 * Display order: chronological by entry date (not selection priority).
 * Manual vs. derived is a selection-time distinction only; readers see a
 * single uniformly-sorted list. Rules for the manual list are documented in
 * STYLE_GUIDE.md and enforced by scripts/check-internal-links.mjs.
 */
import { getCollection } from 'astro:content';
import { useTranslations, formatDate, localePath } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
import derivedData from '../data/derived-related.json';

const MAX_DISPLAY = 10;
const derivedMap = derivedData as Record<string, { id: string; score: number }[]>;

interface Props {
  lang: Lang;
  entryId: string;
  relatedIds: string[];
}

const { lang, entryId, relatedIds } = Astro.props;
const t = useTranslations(lang);

// Build the selection set: manual first so they survive the cap, then
// derived candidates (already score-sorted, with deterministic tiebreakers).
// The final display is sorted chronologically further below.
const seen = new Set(relatedIds);
const derivedIds = (derivedMap[entryId] ?? [])
  .map((d) => d.id)
  .filter((id) => !seen.has(id));
const mergedIds = [...relatedIds, ...derivedIds].slice(0, MAX_DISPLAY);

interface Target {
  id: string;
  title: string;
  date: Date;
  href: string;
}

let targets: Target[] = [];

if (mergedIds.length > 0) {
  const collectionName = lang === 'ja' ? 'entries_ja' : 'entries';
  const all = await getCollection(collectionName as 'entries');
  const byId = new Map(all.map((e) => [e.id, e]));

  targets = mergedIds
    .map((id): Target | null => {
      const entry = byId.get(id);
      if (!entry) return null;

      // Biography entries are not routed at /entries/{id}/ — they live at
      // /participants/{slug}/. Use the primary participant slug from the
      // biography frontmatter.
      let href: string;
      if (entry.data.type === 'biography') {
        const primarySlug = entry.data.participants?.[0]?.slug;
        if (!primarySlug) return null;
        href = localePath(`/participants/${primarySlug}/`, lang);
      } else {
        href = localePath(`/entries/${entry.id}/`, lang);
      }

      return {
        id: entry.id,
        title: entry.data.title,
        date: entry.data.date,
        href,
      };
    })
    .filter((x): x is Target => x !== null)
    .sort((a, b) => a.date.getTime() - b.date.getTime());
}
---

{targets.length > 0 && (
  <section class="related-entries">
    <h2>{t('related.heading' as any)}</h2>
    <ul>
      {targets.map((entry) => (
        <li>
          <a href={entry.href}>
            <time datetime={entry.date.toISOString()}>{formatDate(entry.date, lang)}</time>
            <span class="related-title">{entry.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .related-entries {
    margin: 2.5rem 0;
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-alt);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 4px 4px 0;
  }
  .related-entries h2 {
    margin: 0 0 0.75rem;
    font-size: 1rem;
    font-family: var(--font-heading);
    color: var(--color-text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .related-entries ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .related-entries li {
    margin: 0.4rem 0;
  }
  .related-entries a {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    line-height: 1.5;
  }
  .related-entries a:hover .related-title {
    color: var(--color-link);
    text-decoration: underline;
  }
  .related-entries time {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 6.5rem;
  }
  .related-title {
    font-size: 0.95rem;
  }
</style>
