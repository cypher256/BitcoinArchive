---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, absoluteUrl } from '../../i18n/utils';

const lang = 'ja';
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title={`${t('nav.search')} - ${t('site.title')}`}
  description="ビットコイン・インスティテュートを検索"
  lang={lang}
  alternateEn={absoluteUrl('/search/', 'en')}
  noindex={true}
>
  <div class="container">
    <h1>{t('nav.search')}</h1>
    <link href={`${base}/pagefind/pagefind-ui.css`} rel="stylesheet" />
    <script is:inline src={`${base}/pagefind/pagefind-ui.js`}></script>
    <div id="search"></div>
    <script is:inline define:vars={{ searchBase: `${base}/` }}>
      window.addEventListener('DOMContentLoaded', () => {
        new PagefindUI({
          element: '#search',
          showSubResults: true,
          baseUrl: searchBase,
        });
      });
    </script>
  </div>
</BaseLayout>

<style>
  #search {
    margin-top: 1rem;
  }
</style>
