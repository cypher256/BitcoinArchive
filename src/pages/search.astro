---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations, absoluteUrl } from '../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---

<BaseLayout
  title={`${t('nav.search')} - ${t('site.title')}`}
  description={t('search.description')}
  lang={lang}
  alternateJa={absoluteUrl('/search/', 'ja')}
  noindex={true}
>
  <div class="container">
    <h1>{t('nav.search')}</h1>
    <div id="searchbox"></div>
    <div id="stats"></div>
    <div id="hits"></div>
    <div id="pagination"></div>
  </div>
</BaseLayout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/instantsearch.css@8/themes/satellite-min.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/algoliasearch@4.24.0/dist/algoliasearch-lite.umd.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/instantsearch.js@4.75.6/dist/instantsearch.production.min.js"></script>

<style>
  .container { max-width: 800px; margin: 0 auto; padding: 1rem; }
  #searchbox { margin: 1rem 0; }
  #stats { font-size: 0.85rem; color: #666; margin-bottom: 1rem; }
  .hit-item { padding: 1rem 0; border-bottom: 1px solid #eee; }
  .hit-item a { text-decoration: none; color: inherit; display: block; }
  .hit-item a:hover { background: #f9f9f9; }
  .hit-title { font-size: 1.1rem; font-weight: bold; color: #c45a2c; margin-bottom: 0.25rem; }
  .hit-meta { font-size: 0.8rem; color: #888; margin-bottom: 0.5rem; }
  .hit-meta .satoshi { color: #c45a2c; font-weight: bold; }
  .hit-snippet { font-size: 0.9rem; color: #444; }
  .hit-snippet mark, .hit-title mark { background: #fff3cd; padding: 0 2px; }
  .ais-Pagination-list { display: flex; gap: 0.5rem; list-style: none; padding: 1rem 0; justify-content: center; }
  .ais-Pagination-item--selected .ais-Pagination-link { font-weight: bold; color: #c45a2c; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var searchClient = algoliasearch('FI2GZVF3TY', 'c0328bda37db1cc886aacffb2aed5425');

    var search = instantsearch({
      indexName: 'bitcoin_archive_en',
      searchClient: searchClient,
    });

    search.addWidgets([
      instantsearch.widgets.searchBox({
        container: '#searchbox',
        placeholder: 'Search...',
        autofocus: true,
      }),
      instantsearch.widgets.stats({
        container: '#stats',
        templates: {
          text: function(data) {
            return data.nbHits + ' results (' + data.processingTimeMS + 'ms)';
          },
        },
      }),
      instantsearch.widgets.hits({
        container: '#hits',
        templates: {
          item: function(hit) {
            var author = hit.isSatoshi
              ? '<span class="satoshi">' + hit.author + '</span>'
              : '<span>' + hit.author + '</span>';
            var date = hit.date
              ? ' · ' + new Date(hit.date).toLocaleDateString('en-US')
              : '';
            var type = hit.type ? ' · ' + hit.type : '';
            var title = instantsearch.highlight({ attribute: 'title', hit: hit });
            var snippet = instantsearch.snippet({ attribute: 'body', hit: hit });
            return '<div class="hit-item"><a href="' + hit.url + '">'
              + '<div class="hit-title">' + title + '</div>'
              + '<div class="hit-meta">' + author + date + type + '</div>'
              + '<div class="hit-snippet">' + snippet + '</div>'
              + '</a></div>';
          },
          empty: function() { return '<p>No results found</p>'; },
        },
      }),
      instantsearch.widgets.pagination({
        container: '#pagination',
      }),
    ]);

    search.start();
  });
</script>
