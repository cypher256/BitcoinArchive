---
/**
 * RelatedEntries.astro — Renders the "Related entries" section on entry pages.
 *
 * Selection policy (manual-first, no data-side cap):
 *   1. Start from manual frontmatter.relatedEntries (editor-curated,
 *      priority-ordered — see STYLE_GUIDE "Related Entries").
 *   2. Append auto-derived candidates from src/data/derived-related.json
 *      (computed by scripts/generate-derived-related.mjs from inline-link
 *      structure) that are not already in the manual list.
 *
 * Display policy (cap is at the display layer, not the data layer):
 *   - The first MAX_VISIBLE items (after chronological sort) are shown
 *     immediately.
 *   - Any remainder is rendered inside a <details> block ("Show N more")
 *     so the data layer keeps the full graph while the UI stays compact.
 *   - <details> is HTML-standard, requires no JS, and is keyboard /
 *     screen-reader accessible.
 *
 * Display order: chronological by entry date (not selection priority).
 * Selection priority controls *what gets in*; chronology controls *how
 * it reads*. Rules for the manual list are documented in STYLE_GUIDE.md
 * and the bidirectional / EN-JA-mirror constraints are enforced by
 * scripts/check-internal-links.mjs.
 */
import { getCollection } from 'astro:content';
import { useTranslations, formatDate, localePath } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
import derivedData from '../data/derived-related.json';

const MAX_VISIBLE = 5;
const derivedMap = derivedData as Record<string, { id: string; score: number }[]>;

interface Props {
  lang: Lang;
  entryId: string;
  relatedIds: string[];
}

const { lang, entryId, relatedIds } = Astro.props;
const t = useTranslations(lang);

// Build the selection set in priority order: manual first (priority-ordered
// per STYLE_GUIDE), then derived candidates (already score-sorted, with
// deterministic tiebreakers). No data-side cap — the cap is at the display
// layer below, where the priority-top MAX_VISIBLE items are always shown
// and the remainder is rendered inside a <details> ("Show N more") block.
const seen = new Set(relatedIds);
const derivedIds = (derivedMap[entryId] ?? [])
  .map((d) => d.id)
  .filter((id) => !seen.has(id));
const mergedIds = [...relatedIds, ...derivedIds];

const visibleIds = mergedIds.slice(0, MAX_VISIBLE);
const hiddenIds = mergedIds.slice(MAX_VISIBLE);

interface Target {
  id: string;
  title: string;
  date: Date;
  href: string;
}

let visibleTargets: Target[] = [];
let hiddenTargets: Target[] = [];

if (mergedIds.length > 0) {
  const collectionName = lang === 'ja' ? 'entries_ja' : 'entries';
  const all = await getCollection(collectionName as 'entries');
  const byId = new Map(all.map((e) => [e.id, e]));

  // Biography entries are not routed at /entries/{id}/ — they live at
  // /participants/{slug}/. Use the primary participant slug from the
  // biography frontmatter.
  const buildTarget = (id: string): Target | null => {
    const entry = byId.get(id);
    if (!entry) return null;

    let href: string;
    if (entry.data.type === 'biography') {
      const primarySlug = entry.data.participants?.[0]?.slug;
      if (!primarySlug) return null;
      href = localePath(`/participants/${primarySlug}/`, lang);
    } else {
      href = localePath(`/entries/${entry.id}/`, lang);
    }

    return {
      id: entry.id,
      title: entry.data.title,
      date: entry.data.date,
      href,
    };
  };

  const byDate = (a: Target, b: Target) => a.date.getTime() - b.date.getTime();

  visibleTargets = visibleIds
    .map(buildTarget)
    .filter((x): x is Target => x !== null)
    .sort(byDate);

  hiddenTargets = hiddenIds
    .map(buildTarget)
    .filter((x): x is Target => x !== null)
    .sort(byDate);
}

const showMoreLabel = t('related.showMore' as any).replace('{n}', String(hiddenTargets.length));
---

{visibleTargets.length > 0 && (
  <section class="related-entries">
    <h2>{t('related.heading' as any)}</h2>
    <ul>
      {visibleTargets.map((entry) => (
        <li>
          <a href={entry.href}>
            <time datetime={entry.date.toISOString()}>{formatDate(entry.date, lang)}</time>
            <span class="related-title">{entry.title}</span>
          </a>
        </li>
      ))}
    </ul>
    {hiddenTargets.length > 0 && (
      <details class="related-more">
        <summary>{showMoreLabel}</summary>
        <ul>
          {hiddenTargets.map((entry) => (
            <li>
              <a href={entry.href}>
                <time datetime={entry.date.toISOString()}>{formatDate(entry.date, lang)}</time>
                <span class="related-title">{entry.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </details>
    )}
  </section>
)}

<style>
  .related-entries {
    margin: 2.5rem 0;
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-alt);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 4px 4px 0;
  }
  .related-entries h2 {
    margin: 0 0 0.75rem;
    font-size: 1rem;
    font-family: var(--font-heading);
    color: var(--color-text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .related-entries ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .related-entries li {
    margin: 0.4rem 0;
  }
  .related-entries a {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    line-height: 1.5;
  }
  .related-entries a:hover .related-title {
    color: var(--color-link);
    text-decoration: underline;
  }
  .related-entries time {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 6.5rem;
  }
  .related-title {
    font-size: 0.95rem;
  }
  .related-more {
    margin-top: 0.5rem;
  }
  .related-more > summary {
    cursor: pointer;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-family: var(--font-heading);
    padding: 0.4rem 0;
    user-select: none;
    list-style-position: inside;
  }
  .related-more > summary:hover {
    color: var(--color-link);
  }
  .related-more[open] > summary {
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }
  .related-more ul {
    margin-top: 0.4rem;
  }
</style>
