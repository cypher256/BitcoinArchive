---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EntryMeta from '../../../components/EntryMeta.astro';
import SourceCitation from '../../../components/SourceCitation.astro';
import AutoLinkNames from '../../../components/AutoLinkNames.astro';
import RelatedEntries from '../../../components/RelatedEntries.astro';
import SatoshiCodeAnalysis from '../../../components/SatoshiCodeAnalysis.astro';
import SatoshiActivityTimeline from '../../../components/SatoshiActivityTimeline.astro';
import PatoshiNonceLsb from '../../../components/PatoshiNonceLsb.astro';
import SvnCommitters from '../../../components/SvnCommitters.astro';
import PatoshiMiningMachine from '../../../components/PatoshiMiningMachine.astro';
import ValueOverflowTimeline from '../../../components/ValueOverflowTimeline.astro';
import GenesisBlockGap from '../../../components/GenesisBlockGap.astro';
import LoppHashrateAnalysis from '../../../components/LoppHashrateAnalysis.astro';
import PatoshiExtraNonce from '../../../components/PatoshiExtraNonce.astro';
import PlosPatoshiAnomaly from '../../../components/PlosPatoshiAnomaly.astro';
import GitHubMigrationTimeline from '../../../components/GitHubMigrationTimeline.astro';
import SatoshiHoldingsComparison from '../../../components/SatoshiHoldingsComparison.astro';
import WhaleAlertFortune from '../../../components/WhaleAlertFortune.astro';
import NlsExchangeRate from '../../../components/NlsExchangeRate.astro';
import StylometricDistanceHistogram from '../../../components/StylometricDistanceHistogram.astro';
import BitcoinForkGenealogy from '../../../components/BitcoinForkGenealogy.astro';
import { getCollection, render } from 'astro:content';
import { useTranslations, localePath, absoluteUrl } from '../../../i18n/utils';
import { resolveThreadId } from '../../../data/threads';
import { renderEditorNote } from '../../../lib/editor-note';
import gitDates from '../../../data/git-dates.json';

export async function getStaticPaths() {
  const jaEntries = await getCollection('entries_ja');
  const enEntries = await getCollection('entries');
  const enIds = new Set(enEntries.filter((e) => e.data.type !== 'biography').map((e) => e.id));
  return jaEntries.filter((e) => e.data.type !== 'biography').map((entry) => ({
    params: { slug: entry.id },
    props: { entry, hasEn: enIds.has(entry.id) },
  }));
}

const lang = 'ja';
const t = useTranslations(lang);
const { entry, hasEn } = Astro.props;
const { Content } = await render(entry);

const allEntries = await getCollection('entries_ja');
const sorted = allEntries.filter((e) => e.data.type !== 'biography').sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const currentIndex = sorted.findIndex((e) => e.id === entry.id);
const prev = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const next = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

const threadId = resolveThreadId(entry);
const threadMessages = threadId
  ? allEntries.filter((e) => resolveThreadId(e) === threadId).length
  : 0;
const breadcrumbs = [
  { name: t('nav.home'), url: localePath('/', lang) },
  { name: t('nav.entries'), url: localePath('/entries/', lang) },
  { name: entry.data.title, url: localePath(`/entries/${entry.id}/`, lang) },
];

// Content last-updated date from git history (separate axis from
// frontmatter.date which is the entry's anchor to the historical event).
// git-dates.json keys per-language records (en / ja). EN and JA are usually
// edited together so the two updatedAt values are typically identical, but they
// diverge legitimately when only one side is touched (e.g. a JA-only translation
// pass). Each language page reads its own record (JA falls back to EN if the JA
// file isn't yet in git history).
type LangDate = { createdAt: string; updatedAt: string };
type GitDateRecord = { en?: LangDate; ja?: LangDate };
const gitDateRecord =
  (gitDates as Record<string, GitDateRecord>)[entry.id]?.ja ??
  (gitDates as Record<string, GitDateRecord>)[entry.id]?.en;
const updatedAt = gitDateRecord?.updatedAt ? new Date(gitDateRecord.updatedAt) : undefined;
---

<BaseLayout
  title={`${entry.data.title} - ${t('site.title')}`}
  description={entry.data.description}
  lang={lang}
  alternateEn={hasEn ? absoluteUrl(`/entries/${entry.id}/`, 'en') : undefined}
  ogType="article"
  publishedTime={entry.data.date}
  author={entry.data.author}
  ogImage={`/og/ja/${entry.id}.png`}
  breadcrumbs={breadcrumbs}
>
  <article class="container">
    <nav class="entry-nav entry-nav-top">
      {prev && (
        <a href={localePath(`/entries/${prev.id}/`, lang)} class="nav-prev">
          &larr; {prev.data.title}
        </a>
      )}
      {next && (
        <a href={localePath(`/entries/${next.id}/`, lang)} class="nav-next">
          {next.data.title} &rarr;
        </a>
      )}
    </nav>
    <header class="entry-header">
      <h1>{entry.data.title}</h1>
      <EntryMeta
        date={entry.data.date}
        author={entry.data.author}
        entryType={entry.data.type}
        source={entry.data.source}
        sourceUrl={entry.data.sourceUrl}
        isSatoshi={entry.data.isSatoshi}
        lang={lang}
        participants={entry.data.participants}
        tags={entry.data.tags}
        updatedAt={updatedAt}
      />
    </header>

    {entry.data.editorNote && (
      <aside class="editor-note">
        <span class="editor-note-label">📝 編者注（ビットコイン・インスティテュート）</span>
        <p set:html={renderEditorNote(entry.data.editorNote)}></p>
      </aside>
    )}

    {entry.id.includes('value-overflow-incident') && (
      <ValueOverflowTimeline lang={lang} />
    )}

    {entry.id.includes('genesis-block-5-day-mystery') && (
      <GenesisBlockGap lang={lang} />
    )}

    {entry.id.includes('van-dorst-corpus-reanalysis-named-candidates') && (
      <StylometricDistanceHistogram lang={lang} />
    )}

    {entry.id.includes('bitcoin-fork-and-altcoin-genealogy') && (
      <BitcoinForkGenealogy lang={lang} />
    )}

    <div class:list={["entry-content", { "conversation-thread": entry.data.isConversation }]}>
      <Content />
    </div>

    {entry.data.type === 'analysis' && entry.id.includes('satoshi-code') && (
      <SatoshiCodeAnalysis lang={lang} />
    )}

    {entry.data.type === 'analysis' && entry.id.includes('satoshi-activity-timeline') && (
      <SatoshiActivityTimeline lang={lang} />
    )}

    {entry.id.includes('sergio-lerner-nonce-lsb') && (
      <PatoshiNonceLsb lang={lang} />
    )}

    {entry.id.includes('bitcoin-svn-repository-committers') && (
      <SvnCommitters lang={lang} />
    )}

    {entry.id.includes('sergio-lerner-patoshi-mining-machine') && (
      <PatoshiMiningMachine lang={lang} />
    )}

    {entry.id.includes('lopp-was-satoshi-greedy-miner') && (
      <LoppHashrateAnalysis lang={lang} />
    )}

    {entry.id.includes('sergio-lerner-patoshi-analysis') && (
      <PatoshiExtraNonce lang={lang} />
    )}

    {entry.id.includes('plos-one-patoshi-anomaly-study') && (
      <PlosPatoshiAnomaly lang={lang} />
    )}

    {entry.id.includes('bitcoin-github-migration-committers') && (
      <GitHubMigrationTimeline lang={lang} />
    )}

    {entry.id.includes('satoshi-bitcoin-holdings-analysis') && (
      <SatoshiHoldingsComparison lang={lang} />
    )}

    {entry.id.includes('whale-alert-satoshi-fortune') && (
      <WhaleAlertFortune lang={lang} />
    )}

    {entry.id.includes('newlibertystandard-first-exchange-rate') && (
      <NlsExchangeRate lang={lang} />
    )}

    {threadId && threadMessages >= 2 && (
      <div class="thread-banner">
        <a href={localePath(`/entries/threads/${threadId}/`, lang)}>
          スレッド全体を見る（{threadMessages}件） &rarr;
        </a>
      </div>
    )}

    <RelatedEntries lang={lang} entryId={entry.id} relatedIds={entry.data.relatedEntries ?? []} />

    <SourceCitation
      sourceUrl={entry.data.sourceUrl}
      sourceNote={entry.data.sourceNote}
      secondarySources={entry.data.secondarySources}
      pdfMetadata={entry.data.pdfMetadata}
      lang={lang}
      entryType={entry.data.type}
    />

    <nav class="entry-nav">
      {prev && (
        <a href={localePath(`/entries/${prev.id}/`, lang)} class="nav-prev">
          &larr; {prev.data.title}
        </a>
      )}
      {next && (
        <a href={localePath(`/entries/${next.id}/`, lang)} class="nav-next">
          {next.data.title} &rarr;
        </a>
      )}
    </nav>
  </article>
  <AutoLinkNames lang={lang} selectors=".entry-content, .satoshi-analysis" />
</BaseLayout>

<style>
  .entry-header {
    padding-top: 2rem;
    margin-bottom: 2rem;
  }
  .entry-header h1 {
    margin: 0 0 0.75rem;
    font-size: 2rem;
  }
  .editor-note {
    display: block;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0 0 2rem;
    padding: 0.75rem 1rem;
    border-left: 3px solid var(--color-border);
    background: var(--color-bg-alt);
  }
  .editor-note p {
    margin: 0;
  }
  .editor-note-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-accent);
    margin-right: 0.5em;
    margin-bottom: 0.25em;
    font-weight: 600;
  }
  .entry-content { line-height: 1.8; }
  .entry-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-heading);
    font-size: 0.9rem;
  }
  .entry-nav-top {
    margin-top: 0;
    padding-top: 1rem;
    border-top: none;
    margin-bottom: 0;
  }
  .nav-prev, .nav-next { max-width: 45%; }
  .nav-next { margin-left: auto; text-align: right; }
  .thread-banner {
    margin: 1.5rem 0;
    padding: 0.75rem 1rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 4px 4px 0;
    font-family: var(--font-heading);
    font-size: 0.9rem;
  }
  .thread-banner a {
    font-weight: 600;
  }
</style>
