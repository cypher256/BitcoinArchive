---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, absoluteUrl } from '../../i18n/utils';

const lang = 'ja';
const t = useTranslations(lang);
---

<BaseLayout
  title={`${t('nav.search')} - ${t('site.title')}`}
  description={t('search.description')}
  lang={lang}
  alternateEn={absoluteUrl('/search/', 'en')}
  noindex={true}
>
  <div class="container">
    <h1>{t('nav.search')}</h1>
    <div id="searchbox"></div>
    <div id="stats"></div>
    <div id="hits"></div>
    <div id="pagination"></div>
  </div>
</BaseLayout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/instantsearch.css@8/themes/satellite-min.css" />

<style>
  .container { max-width: 800px; margin: 0 auto; padding: 1rem; }
  #searchbox { margin: 1rem 0; }
  #stats { font-size: 0.85rem; color: #666; margin-bottom: 1rem; }
  .hit-item { padding: 1rem 0; border-bottom: 1px solid #eee; }
  .hit-item a { text-decoration: none; color: inherit; display: block; }
  .hit-item a:hover { background: #f9f9f9; }
  .hit-title { font-size: 1.1rem; font-weight: bold; color: #c45a2c; margin-bottom: 0.25rem; }
  .hit-meta { font-size: 0.8rem; color: #888; margin-bottom: 0.5rem; }
  .hit-meta .satoshi { color: #c45a2c; font-weight: bold; }
  .hit-snippet { font-size: 0.9rem; color: #444; }
  .hit-snippet mark, .hit-title mark { background: #fff3cd; padding: 0 2px; }
  .ais-Pagination-list { display: flex; gap: 0.5rem; list-style: none; padding: 1rem 0; justify-content: center; }
  .ais-Pagination-item--selected .ais-Pagination-link { font-weight: bold; color: #c45a2c; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', async () => {
    const { liteClient } = await import('https://cdn.jsdelivr.net/npm/algoliasearch@5/dist/lite/lite.esm.browser.js');
    const { instantsearch, searchBox, hits, stats, pagination } = await import('https://cdn.jsdelivr.net/npm/instantsearch.js@4/es/index.js')
      .catch(() => null) || {};

    // Fallback: load via script tags if ESM import fails
    if (!instantsearch) {
      const s1 = document.createElement('script');
      s1.src = 'https://cdn.jsdelivr.net/npm/algoliasearch@5/dist/lite/algoliasearch.lite.umd.js';
      document.head.appendChild(s1);
      const s2 = document.createElement('script');
      s2.src = 'https://cdn.jsdelivr.net/npm/instantsearch.js@4';
      document.head.appendChild(s2);
      await new Promise(r => s2.onload = r);
      startSearch(window.algoliasearch, window.instantsearch);
    } else {
      startSearch(liteClient, instantsearch);
    }
  });

  function startSearch(algoliasearch, instantsearch) {
    const searchClient = algoliasearch('FI2GZVF3TY', 'c0328bda37db1cc886aacffb2aed5425');

    const search = instantsearch({
      indexName: 'bitcoin_archive_ja',
      searchClient,
    });

    search.addWidgets([
      instantsearch.widgets.searchBox({
        container: '#searchbox',
        placeholder: '検索...',
        autofocus: true,
      }),
      instantsearch.widgets.stats({
        container: '#stats',
        templates: {
          text: (data) => `${data.nbHits}件の検索結果（${data.processingTimeMS}ms）`,
        },
      }),
      instantsearch.widgets.hits({
        container: '#hits',
        templates: {
          item: (hit, { html, components }) => html`
            <div class="hit-item">
              <a href="${hit.url}">
                <div class="hit-title">${components.Highlight({ hit, attribute: 'title' })}</div>
                <div class="hit-meta">
                  <span class="${hit.isSatoshi ? 'satoshi' : ''}">${hit.author}</span>
                  ${hit.date ? ` · ${new Date(hit.date).toLocaleDateString('ja-JP')}` : ''}
                  ${hit.type ? ` · ${hit.type}` : ''}
                </div>
                <div class="hit-snippet">${components.Snippet({ hit, attribute: 'body' })}</div>
              </a>
            </div>
          `,
          empty: () => '<p>検索結果がありません</p>',
        },
      }),
      instantsearch.widgets.pagination({
        container: '#pagination',
      }),
    ]);

    search.start();
  }
</script>
