---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/ui';
import '../styles/global.css';
// Theme bundle (Phase 3.5): all five Modern variants plus a snapshot
// of the current retro look are imported once and shipped as a single
// CSS bundle. Each file scopes its rules to `:root[data-theme="..."]`,
// so without an explicit data-theme nothing fires and the
// global.css defaults (= retro) win. The retro snapshot lets users
// flip back to the current look via `?theme=retro` for A/B compare.
// Once a Modern theme is adopted (Phase 6) these files and the
// imports below get removed and the chosen palette is promoted to
// the global.css :root defaults.
import '../styles/themes/retro.css';
import '../styles/themes/modern-a.css';
import '../styles/themes/modern-b.css';
import '../styles/themes/modern-c.css';
import '../styles/themes/modern-d.css';
import '../styles/themes/modern-e.css';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  canonicalUrl?: string;
  alternateJa?: string;
  alternateEn?: string;
  ogType?: 'website' | 'article';
  publishedTime?: Date;
  author?: string;
  noindex?: boolean;
  ogImage?: string;
  breadcrumbs?: Array<{
    name: string;
    url: string;
  }>;
  structuredData?: Record<string, any> | Array<Record<string, any>>;
}

const { title, description, lang, canonicalUrl, alternateJa, alternateEn, ogType, publishedTime, author, noindex, ogImage, breadcrumbs, structuredData } = Astro.props;
// Server-side theme attribute. In dev (SSR) Astro.url carries the
// real query string, so `?theme=modern-a` is wired into the HTML
// before the first byte. In static build (SSG) the attribute is
// emitted empty; the head-earliest inline script below picks up
// the URL param at runtime instead. Either way the attribute is
// set before stylesheets resolve, so no FOUC.
const themeParam = Astro.url.searchParams.get('theme') || '';
---

<!doctype html>
<html lang={lang} data-theme={themeParam}>
  <head>
    {/*
      Head-earliest inline blocking script. This MUST be the first
      child of <head> so it runs before any stylesheet or font
      <link> resolves. It does three things:

      1. Read `?theme=...` from the URL and apply it to <html>
         (covers SSG where the server-side attribute is empty).
      2. Read `localStorage.mode` and apply `data-mode` to <html>
         (3-way: light / dark / system; system = no attribute).
      3. Sync `<meta name="theme-color">` with the current
         computed `--color-bg` so the mobile browser chrome
         tracks the theme/mode in real time. Listens for OS
         dark-mode flips and any later attribute mutations.

      Wrapped in a try/catch because localStorage can throw in
      private browsing modes — silent fallback to defaults is
      better than blowing up first paint.
    */}
    <script is:inline>
      (function () {
        try {
          var root = document.documentElement;
          var p = new URLSearchParams(location.search).get('theme');
          if (p) root.setAttribute('data-theme', p);
          var m = null;
          try { m = localStorage.getItem('mode'); } catch (_) {}
          if (m === 'light' || m === 'dark') root.setAttribute('data-mode', m);
        } catch (_) {}

        function syncBrowserChrome() {
          var meta = document.querySelector('meta[name="theme-color"]');
          if (!meta) return;
          var bg = getComputedStyle(document.documentElement)
            .getPropertyValue('--color-bg').trim();
          if (bg) meta.setAttribute('content', bg);
        }
        // Run once now (after stylesheets have been parsed by the
        // browser into the cascade — `getComputedStyle` will see
        // the resolved value because the script is parsed in head
        // order, but the bundle below is `<link>` so the value is
        // available in time for first paint on every browser path).
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', syncBrowserChrome);
        } else {
          syncBrowserChrome();
        }
        // Also re-run when OS preference flips, when the user toggles
        // mode/theme, or when any script mutates the attributes.
        try {
          var mq = matchMedia('(prefers-color-scheme: dark)');
          if (mq.addEventListener) mq.addEventListener('change', syncBrowserChrome);
          // Legacy fallback for browsers without addEventListener on
          // MediaQueryList (Safari < 14). Deprecated but still the
          // only API there.
          // @ts-ignore
          else if (mq.addListener) mq.addListener(syncBrowserChrome);
        } catch (_) {}
        try {
          new MutationObserver(syncBrowserChrome).observe(
            document.documentElement,
            { attributes: true, attributeFilter: ['data-mode', 'data-theme'] }
          );
        } catch (_) {}
      })();
    </script>
    <BaseHead
      title={title}
      description={description}
      lang={lang}
      canonicalUrl={canonicalUrl}
      alternateJa={alternateJa}
      alternateEn={alternateEn}
      ogType={ogType}
      publishedTime={publishedTime}
      author={author}
      noindex={noindex}
      ogImage={ogImage}
      breadcrumbs={breadcrumbs}
      structuredData={structuredData}
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css" integrity="sha384-zh0CIslj+VczCZtlzBcjt5ppRcsAmDnRem7ESsYwWwg3m/OaJ2l4x7YBZl9Kxxib" crossorigin="anonymous">
  </head>
  <body>
    <Header lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
