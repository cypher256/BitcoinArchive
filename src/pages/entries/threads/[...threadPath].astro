---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { useTranslations, formatDate, localePath, findAuthorParticipant, absoluteUrl } from '../../../i18n/utils';
import { deriveThreadTitle, resolveThreadId } from '../../../data/threads';
import AutoLinkNames from '../../../components/AutoLinkNames.astro';

export async function getStaticPaths() {
  const entries = await getCollection('entries');
  const threadMap = new Map<string, typeof entries>();

  for (const entry of entries) {
    const tid = resolveThreadId(entry);
    if (tid) {
      const list = threadMap.get(tid) || [];
      list.push(entry);
      threadMap.set(tid, list);
    }
  }

  // 日本語側に存在するスレッドIDを取得
  const jaEntries = await getCollection('entries_ja');
  const jaThreadCounts = new Map<string, number>();
  for (const entry of jaEntries) {
    const tid = resolveThreadId(entry);
    if (tid) {
      jaThreadCounts.set(tid, (jaThreadCounts.get(tid) || 0) + 1);
    }
  }

  return [...threadMap.entries()]
    .filter(([_, msgs]) => msgs.length >= 2)
    .map(([threadId, msgs]) => {
      msgs.sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());
      return {
        params: { threadPath: threadId },
        props: {
          messages: msgs,
          threadTitle: deriveThreadTitle(threadId, msgs, 'en'),
          hasJa: (jaThreadCounts.get(threadId) || 0) >= 2,
        },
      };
    });
}

const lang = 'en';
const t = useTranslations(lang);
const { messages, threadTitle, hasJa } = Astro.props;

const rendered = await Promise.all(
  messages.map(async (msg: any) => {
    const { Content } = await render(msg);
    return { entry: msg, Content };
  })
);

const participantMap = new Map<string, { name: string; slug: string }>();
for (const m of messages) {
  for (const p of m.data.participants) {
    if (!participantMap.has(p.slug)) {
      participantMap.set(p.slug, p);
    }
  }
}
const participants = Array.from(participantMap.values());
const dateRange = `${formatDate(messages[0].data.date, lang)} — ${formatDate(messages[messages.length - 1].data.date, lang)}`;
const source = messages[0].data.source;
const sourceLabel = t(`source.${source}` as any) || source;
const breadcrumbs = [
  { name: t('nav.home'), url: localePath('/', lang) },
  { name: t('nav.entries'), url: localePath('/entries/', lang) },
  { name: threadTitle, url: localePath(`/entries/threads/${Astro.params.threadPath}/`, lang) },
];
---

<BaseLayout
  title={`${threadTitle} — Thread - ${t('site.title')}`}
  description={`Full conversation thread: ${threadTitle} (${messages.length} messages)`}
  lang={lang}
  alternateJa={hasJa ? absoluteUrl(`/entries/threads/${Astro.params.threadPath}/`, 'ja') : undefined}
  breadcrumbs={breadcrumbs}
>
  <article class="container">
    <header class="thread-header">
      <h1>{threadTitle}</h1>
      <div class="thread-meta">
        <span class="thread-count">{messages.length} messages</span>
        <a href={localePath(`/sources/${source}/`, lang)} class="source-badge">{sourceLabel}</a>
        <span class="thread-participants">
          {participants.map((p, i) => (
            <>
              <a href={localePath(`/participants/${p.slug}/`, lang)} class:list={["participant-link", { satoshi: p.name === 'Satoshi Nakamoto' }]}>{p.name}</a>{i < participants.length - 1 && ', '}
            </>
          ))}
        </span>
        <span class="thread-dates">{dateRange}</span>
      </div>
    </header>

    <div class="conversation-thread">
      {rendered.map(({ entry, Content }: any, i: number) => (
        <>
          {i > 0 && <div class="thread-connector" />}
          <div class="message" data-author={entry.data.isSatoshi ? 'satoshi' : 'other'} id={entry.data.sourceUrl?.match(/msg(\d+)#/)?.[0]?.replace('#', '') || ''}>
            <div class="message-header">
              {(() => {
                const ap = findAuthorParticipant(entry.data.author, entry.data.participants);
                const displayName = ap?.name ?? entry.data.author;
                const showHandle = ap && displayName !== entry.data.author;
                // Color the author name only when the author actually is
                // Satoshi. Same logic as EntryCard/EntryMeta/search.
                const isSatoshiAuthor =
                  ap?.slug === 'satoshi-nakamoto' ||
                  entry.data.author.toLowerCase() === 'satoshi nakamoto';
                return (
                  <a href={localePath(`/participants/${ap?.slug || entry.data.author}/`, lang)} class:list={["author-name", { satoshi: isSatoshiAuthor }]}>
                    {displayName}{showHandle && <span class="author-handle"> ({entry.data.author})</span>}
                  </a>
                );
              })()}
              <span class="message-date">{formatDate(entry.data.date, lang)}</span>
              <span class="message-source">
                <a href={entry.data.sourceUrl} target="_blank" rel="noopener">Source</a>
                {' · '}
                <a href={localePath(`/entries/${entry.id}/`, lang)}>Permalink</a>
              </span>
            </div>
            <div class="message-body">
              <Content />
            </div>
          </div>
        </>
      ))}
    </div>

    <nav class="entry-nav">
      <a href={localePath('/entries/', lang)}>
        &larr; {t('nav.entries')}
      </a>
    </nav>
  </article>
  <AutoLinkNames lang={lang} selectors=".message-body" />
</BaseLayout>

<style>
  .thread-header {
    padding-top: 2rem;
    margin-bottom: 2rem;
  }
  .thread-header h1 {
    margin: 0 0 0.75rem;
    font-size: 2rem;
  }
  .thread-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .thread-count {
    font-weight: 600;
    color: var(--color-accent);
  }
  .source-badge {
    display: inline-block;
    padding: 0.1em 0.5em;
    background: var(--color-source-bg);
    border-radius: 3px;
    font-size: 0.8rem;
    text-decoration: none;
    color: inherit;
  }
  .source-badge:hover {
    opacity: 0.85;
  }
  .participant-link {
    text-decoration: none;
    color: var(--color-text-muted);
  }
  .participant-link:hover {
    color: var(--color-text);
    text-decoration: underline;
  }
  .participant-link.satoshi {
    color: var(--color-satoshi);
    font-weight: 600;
  }
  .author-name {
    text-decoration: none;
    color: inherit;
  }
  .author-name:hover {
    text-decoration: underline;
  }
  .author-name.satoshi {
    color: var(--color-satoshi);
    font-weight: 600;
  }
  .author-handle {
    font-weight: 400;
    font-size: 0.85em;
    color: var(--color-text-muted);
  }
  .entry-nav {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-heading);
    font-size: 0.9rem;
  }
</style>

<script is:inline>
// Rewrite in-thread links to anchor links
(function() {
  var msgIds = new Set();
  var pathToAnchor = {};
  document.querySelectorAll('.message[id]').forEach(function(el) {
    if (!el.id) return;
    msgIds.add(el.id);
    var permalink = el.querySelector('.message-source a:last-child');
    if (permalink) {
      var path = permalink.getAttribute('href');
      if (path) pathToAnchor[path.replace(/\/$/, '')] = '#' + el.id;
    }
  });
  document.querySelectorAll('.message-body a[href]').forEach(function(a) {
    var href = a.getAttribute('href');
    if (!href || href.startsWith('http')) return;
    var m = href.match(/msg(\d+)\/?$/);
    if (m && msgIds.has('msg' + m[1])) {
      a.setAttribute('href', '#msg' + m[1]);
      return;
    }
    var normalized = href.replace(/\/$/, '');
    if (pathToAnchor[normalized]) {
      a.setAttribute('href', pathToAnchor[normalized]);
    }
  });
})();
</script>
