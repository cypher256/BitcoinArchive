---
interface Props {
  title: string;
  description: string;
  lang?: string;
  canonicalUrl?: string;
  alternateJa?: string;
  alternateEn?: string;
  ogType?: 'website' | 'article';
  publishedTime?: Date;
  author?: string;
  noindex?: boolean;
  ogImage?: string;
  breadcrumbs?: Array<{
    name: string;
    url: string;
  }>;
}

const { title, description, lang = 'en', canonicalUrl, alternateJa, alternateEn, ogType = 'website', publishedTime, author, noindex = false, ogImage, breadcrumbs = [] } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = `${Astro.site?.origin || 'https://cypher256.github.io'}${base}`;
// Canonical always points to Cloudflare Pages (primary site)
const canonicalBase = 'https://bitcoin-archive.pages.dev';
const pagePath = Astro.url.pathname.replace(/^\/BitcoinArchive/, '');
const resolvedCanonical = canonicalUrl || `${canonicalBase}${pagePath}`;
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/images/og-default.png`;

// hreflang: 両方の alternate が揃っている場合のみ完全なクラスタを出力
// 片側しか渡されていない場合は、自分自身を補完する
const enUrl = alternateEn || (lang === 'en' ? resolvedCanonical : undefined);
const jaUrl = alternateJa || (lang === 'ja' ? resolvedCanonical : undefined);
const hasHreflang = enUrl && jaUrl;
const breadcrumbItems = breadcrumbs.map((item, index) => ({
  "@type": "ListItem",
  "position": index + 1,
  "name": item.name,
  "item": new URL(item.url, siteUrl).toString(),
}));
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<!-- Google Search Console: GitHub Pages (cypher256.github.io) -->
<meta name="google-site-verification" content="dUyV3q5C-KweMCnu3GmALTNF9Yr9BHvIIJe5IzyR4Mo" />
<!-- Google Search Console: Cloudflare Pages (bitcoin-archive.pages.dev) -->
<meta name="google-site-verification" content="iB8WajDfhHKk7jbDrKODvl6SKNOefazbfxuGXYBNoRk" />
<meta name="theme-color" content="#b45309" />

<title>{title}</title>
<meta name="description" content={description} />

<link rel="canonical" href={resolvedCanonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
{hasHreflang && <link rel="alternate" hreflang="en" href={enUrl} />}
{hasHreflang && <link rel="alternate" hreflang="ja" href={jaUrl} />}
{hasHreflang && <link rel="alternate" hreflang="x-default" href={enUrl} />}

<meta property="og:type" content={ogType} />
<meta property="og:url" content={resolvedCanonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:site_name" content="Bitcoin Archive" />
<meta property="og:locale" content={lang === 'ja' ? 'ja_JP' : 'en_US'} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
{ogType === 'article' && publishedTime && (
  <meta property="article:published_time" content={publishedTime.toISOString()} />
)}

{breadcrumbItems.length >= 2 && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbItems,
  })} />
)}
{ogType === 'article' && author && (
  <meta property="article:author" content={author} />
)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<link rel="sitemap" href={`${base}/sitemap-index.xml`} />
<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
<link rel="apple-touch-icon" href={`${base}/images/apple-touch-icon.png`} />

{/* JSON-LD Structured Data */}
{ogType === 'website' ? (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Bitcoin Archive",
    "url": siteUrl,
    "description": "The world's most comprehensive archive of Satoshi Nakamoto's complete conversations, emails, forum posts, and related historical documents.",
    "inLanguage": [lang === 'ja' ? 'ja' : 'en'],
  })} />
) : (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "url": resolvedCanonical,
    ...(publishedTime ? { "datePublished": publishedTime.toISOString() } : {}),
    ...(author ? { "author": { "@type": "Person", "name": author } } : {}),
    "publisher": {
      "@type": "Organization",
      "name": "Bitcoin Archive",
      "url": siteUrl,
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": resolvedCanonical,
    },
    "inLanguage": lang === 'ja' ? 'ja' : 'en',
  })} />
)}
