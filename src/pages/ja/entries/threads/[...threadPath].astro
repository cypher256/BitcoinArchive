---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { useTranslations, formatDate, formatDateMaybeTime, localePath, translateParticipantName, findAuthorParticipant, absoluteUrl } from '../../../../i18n/utils';
import { deriveThreadTitle, resolveThreadId } from '../../../../data/threads';

export async function getStaticPaths() {
  const entries = await getCollection('entries_ja');
  const threadMap = new Map<string, typeof entries>();

  for (const entry of entries) {
    const tid = resolveThreadId(entry);
    if (tid) {
      const list = threadMap.get(tid) || [];
      list.push(entry);
      threadMap.set(tid, list);
    }
  }

  // 英語側に存在するスレッドIDを取得
  const enEntries = await getCollection('entries');
  const enThreadCounts = new Map<string, number>();
  for (const entry of enEntries) {
    const tid = resolveThreadId(entry);
    if (tid) {
      enThreadCounts.set(tid, (enThreadCounts.get(tid) || 0) + 1);
    }
  }

  // Build a chronologically sorted list of all threads so each thread page
  // can carry prev/next links pointing to adjacent threads, parallel to the
  // per-entry nav on individual pages. Anchor each thread to its first
  // message's date.
  const allThreads = [...threadMap.entries()]
    .filter(([_, msgs]) => msgs.length >= 2)
    .map(([threadId, msgs]) => {
      msgs.sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());
      return { threadId, msgs };
    })
    .sort((a, b) => a.msgs[0].data.date.getTime() - b.msgs[0].data.date.getTime());

  return allThreads.map(({ threadId, msgs }, idx) => {
    const prev = idx > 0 ? allThreads[idx - 1] : null;
    const next = idx < allThreads.length - 1 ? allThreads[idx + 1] : null;
    return {
      params: { threadPath: threadId },
      props: {
        messages: msgs,
        threadTitle: deriveThreadTitle(threadId, msgs, 'ja'),
        hasEn: (enThreadCounts.get(threadId) || 0) >= 2,
        prevThread: prev ? { id: prev.threadId, title: deriveThreadTitle(prev.threadId, prev.msgs, 'ja') } : null,
        nextThread: next ? { id: next.threadId, title: deriveThreadTitle(next.threadId, next.msgs, 'ja') } : null,
      },
    };
  });
}

const lang = 'ja';
const t = useTranslations(lang);
const { messages, threadTitle, hasEn, prevThread, nextThread } = Astro.props;

const rendered = await Promise.all(
  messages.map(async (msg: any) => {
    const { Content } = await render(msg);
    return { entry: msg, Content };
  })
);

const participantMap = new Map<string, { name: string; slug: string }>();
for (const m of messages) {
  for (const p of m.data.participants) {
    if (!participantMap.has(p.slug)) {
      participantMap.set(p.slug, p);
    }
  }
}
const participants = Array.from(participantMap.values());
const dateRange = `${formatDate(messages[0].data.date, lang)} — ${formatDate(messages[messages.length - 1].data.date, lang)}`;
const source = messages[0].data.source;
const sourceLabel = t(`source.${source}` as any) || source;
const breadcrumbs = [
  { name: t('nav.home'), url: localePath('/', lang) },
  { name: t('nav.entries'), url: localePath('/entries/', lang) },
  { name: threadTitle, url: localePath(`/entries/threads/${Astro.params.threadPath}/`, lang) },
];
---

<BaseLayout
  title={`${threadTitle} — スレッド - ${t('site.title')}`}
  description={`会話スレッド: ${threadTitle}（${messages.length}件）`}
  lang={lang}
  alternateEn={hasEn ? absoluteUrl(`/entries/threads/${Astro.params.threadPath}/`, 'en') : undefined}
  breadcrumbs={breadcrumbs}
>
  <article class="container">
    <nav class="entry-nav entry-nav-top">
      {prevThread && (
        <a href={localePath(`/entries/threads/${prevThread.id}/`, lang)} class="nav-prev">
          &larr; {prevThread.title}
        </a>
      )}
      {nextThread && (
        <a href={localePath(`/entries/threads/${nextThread.id}/`, lang)} class="nav-next">
          {nextThread.title} &rarr;
        </a>
      )}
    </nav>
    <header class="thread-header">
      <h1>{threadTitle}</h1>
      <div class="thread-meta">
        <span class="thread-count">{messages.length} 件のメッセージ</span>
        <a href={localePath(`/sources/${source}/`, lang)} class="source-badge">{sourceLabel}</a>
        <span class="thread-participants">
          {participants.map((p, i) => (
            <>
              <a href={localePath(`/participants/${p.slug}/`, lang)} class:list={["participant-link", { satoshi: p.name === 'Satoshi Nakamoto' }]}>{translateParticipantName(p.name, p.slug, lang)}</a>{i < participants.length - 1 && ', '}
            </>
          ))}
        </span>
        <span class="thread-dates">{dateRange}</span>
      </div>
    </header>

    <div class="conversation-thread">
      {rendered.map(({ entry, Content }: any, i: number) => (
        <>
          {i > 0 && <div class="thread-connector" />}
          <div class="message" data-author={entry.data.isSatoshi ? 'satoshi' : 'other'} id={entry.data.sourceUrl?.match(/msg(\d+)#/)?.[0]?.replace('#', '') || ''}>
            <div class="message-header">
              {(() => {
                const ap = findAuthorParticipant(entry.data.author, entry.data.participants);
                const displayName = translateParticipantName(ap?.name ?? entry.data.author, ap?.slug, lang);
                const showHandle = ap && displayName !== entry.data.author;
                // Color the author name only when the author actually is
                // Satoshi. Same logic as EntryCard/EntryMeta/search.
                const isSatoshiAuthor =
                  ap?.slug === 'satoshi-nakamoto' ||
                  entry.data.author.toLowerCase() === 'satoshi nakamoto';
                return (
                  <a href={localePath(`/participants/${ap?.slug || entry.data.author}/`, lang)} class:list={["author-name", { satoshi: isSatoshiAuthor }]}>
                    {displayName}{showHandle && <span class="author-handle">（{entry.data.author}）</span>}
                  </a>
                );
              })()}
              <span class="message-date">{formatDateMaybeTime(entry.data.date, lang)}</span>
              <span class="message-source">
                <a href={entry.data.sourceUrl} target="_blank" rel="noopener">原文</a>
                {' · '}
                <a href={localePath(`/entries/${entry.id}/`, lang)}>個別ページ</a>
              </span>
            </div>
            <div class="message-body">
              <Content />
            </div>
          </div>
        </>
      ))}
    </div>

    <nav class="entry-nav">
      {prevThread && (
        <a href={localePath(`/entries/threads/${prevThread.id}/`, lang)} class="nav-prev">
          &larr; {prevThread.title}
        </a>
      )}
      {nextThread && (
        <a href={localePath(`/entries/threads/${nextThread.id}/`, lang)} class="nav-next">
          {nextThread.title} &rarr;
        </a>
      )}
    </nav>
  </article>
</BaseLayout>

<style>
  .thread-header {
    padding-top: 2rem;
    margin-bottom: 2rem;
  }
  .thread-header h1 {
    margin: 0 0 0.75rem;
    font-size: 2rem;
  }
  .thread-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .thread-count {
    font-weight: 600;
    color: var(--color-text);
  }
  .source-badge {
    display: inline-block;
    padding: 0.1em 0.5em;
    background: var(--color-source-bg);
    border-radius: 3px;
    font-size: 0.8rem;
    text-decoration: none;
    color: inherit;
  }
  .source-badge:hover {
    opacity: 0.85;
  }
  .participant-link {
    text-decoration: none;
    color: var(--color-link);
  }
  .participant-link:hover {
    color: var(--color-link-hover);
    text-decoration: underline;
  }
  .participant-link.satoshi {
    color: var(--color-satoshi);
    font-weight: 600;
  }
  .author-name {
    text-decoration: none;
    color: var(--color-link);
  }
  .author-name:hover {
    color: var(--color-link-hover);
    text-decoration: underline;
  }
  .author-name.satoshi {
    color: var(--color-satoshi);
    font-weight: 600;
  }
  .author-handle {
    font-weight: 400;
    font-size: 0.85em;
    color: var(--color-text-muted);
  }
  .entry-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-heading);
    font-size: 0.9rem;
  }
  .entry-nav-top {
    margin-top: 0;
    padding-top: 1rem;
    border-top: none;
    margin-bottom: 0;
  }
  .nav-prev, .nav-next { max-width: 45%; }
  .nav-next { margin-left: auto; text-align: right; }
</style>

<script is:inline>
// Rewrite in-thread links to anchor links
(function() {
  // Build msgId set and path-to-anchor mapping
  var msgIds = new Set();
  var pathToAnchor = {};
  document.querySelectorAll('.message[id]').forEach(function(el) {
    if (!el.id) return;
    msgIds.add(el.id);
    // Find the permalink (個別ページ) link inside this message to map path -> anchor
    var permalink = el.querySelector('.message-source a:last-child');
    if (permalink) {
      var path = permalink.getAttribute('href');
      if (path) pathToAnchor[path.replace(/\/$/, '')] = '#' + el.id;
    }
  });
  document.querySelectorAll('.message-body a[href]').forEach(function(a) {
    var href = a.getAttribute('href');
    if (!href || href.startsWith('http')) return;
    // Match by msgID in URL
    var m = href.match(/msg(\d+)\/?$/);
    if (m && msgIds.has('msg' + m[1])) {
      a.setAttribute('href', '#msg' + m[1]);
      return;
    }
    // Match by entry path (for links without msgID)
    var normalized = href.replace(/\/$/, '');
    if (pathToAnchor[normalized]) {
      a.setAttribute('href', pathToAnchor[normalized]);
    }
  });
})();
</script>
