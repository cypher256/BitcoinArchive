---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/ui';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  canonicalUrl?: string;
  alternateJa?: string;
  alternateEn?: string;
  ogType?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  noindex?: boolean;
  ogImage?: string;
  breadcrumbs?: Array<{
    name: string;
    url: string;
  }>;
  structuredData?: Record<string, any> | Array<Record<string, any>>;
}

const { title, description, lang, canonicalUrl, alternateJa, alternateEn, ogType, publishedTime, modifiedTime, author, noindex, ogImage, breadcrumbs, structuredData } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    {/*
      Head-earliest inline blocking script. This MUST be the first
      child of <head> so it runs before any stylesheet or font
      <link> resolves. It does three things:

      1. Read `localStorage.mode` and apply `data-mode` to <html>
         (3-way: light / dark / system; system = no attribute).
      2. Ensure `<meta name="theme-color">` exists in <head> and
         seed its content with a fixed hex computed from the active
         mode (no CSS variables — stylesheets haven't loaded yet,
         so `getComputedStyle('--color-bg')` returns empty here).
         This guarantees the mobile browser chrome (address bar,
         task switcher) is correct from the very first paint;
         dark-mode users no longer see a flash of light chrome.
      3. After stylesheets resolve (DOMContentLoaded or later), run
         `syncBrowserChrome()` to refresh the meta from the actual
         `--color-bg` value — handles the rare case where the
         token diverges from the seeded literal, and tracks any
         later mode flip via media query / MutationObserver.

      The seeded literals MUST stay in sync with `--color-bg` in
      `src/styles/global.css` (light: `#ffffff`; dark: `#0e1218`).
      If you change the bg token, change them here too.

      Wrapped in a try/catch because localStorage can throw in
      private browsing modes — silent fallback to defaults is
      better than blowing up first paint.
    */}
    <script is:inline>
      (function () {
        var root = document.documentElement;
        try {
          var m = null;
          try { m = localStorage.getItem('mode'); } catch (_) {}
          if (m === 'light' || m === 'dark') root.setAttribute('data-mode', m);
        } catch (_) {}

        // Resolve the active mode in the same 3-way logic the CSS uses:
        //   data-mode='light'  → light
        //   data-mode='dark'   → dark
        //   no attribute       → follow OS preference
        function activeMode() {
          var attr = root.getAttribute('data-mode');
          if (attr === 'light' || attr === 'dark') return attr;
          try {
            return matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          } catch (_) { return 'light'; }
        }
        // Light / dark `--color-bg` literals from `src/styles/global.css`.
        // Kept in sync manually — see the doc-comment above.
        function bgLiteralFor(mode) {
          return mode === 'dark' ? '#0e1218' : '#ffffff';
        }

        // Ensure the theme-color meta exists in <head>. Created on demand
        // so this script doesn't depend on BaseHead's render order — if
        // <head> emits other tags first, the meta is appended; if a
        // future BaseHead change adds a literal <meta>, this finds it.
        function ensureThemeColorMeta() {
          var meta = document.querySelector('meta[name="theme-color"]');
          if (!meta) {
            meta = document.createElement('meta');
            meta.setAttribute('name', 'theme-color');
            document.head.appendChild(meta);
          }
          return meta;
        }

        // Step 2: seed the meta immediately with the literal for the
        // active mode so the address bar paints correctly on the first
        // frame. Stylesheets are still loading; we cannot read CSS vars.
        var seedMeta = ensureThemeColorMeta();
        seedMeta.setAttribute('content', bgLiteralFor(activeMode()));

        // Step 3: once stylesheets resolve, refresh from the actual
        // `--color-bg` token so any future palette change in global.css
        // propagates without touching the literals above.
        function syncBrowserChrome() {
          var meta = ensureThemeColorMeta();
          var bg = getComputedStyle(root).getPropertyValue('--color-bg').trim();
          if (bg) meta.setAttribute('content', bg);
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', syncBrowserChrome);
        } else {
          syncBrowserChrome();
        }
        // Also re-run when OS preference flips, when the user toggles
        // mode, or when any script mutates the attribute.
        try {
          var mq = matchMedia('(prefers-color-scheme: dark)');
          if (mq.addEventListener) mq.addEventListener('change', syncBrowserChrome);
          // Legacy fallback for browsers without addEventListener on
          // MediaQueryList (Safari < 14). Deprecated but still the
          // only API there.
          // @ts-ignore
          else if (mq.addListener) mq.addListener(syncBrowserChrome);
        } catch (_) {}
        try {
          new MutationObserver(syncBrowserChrome).observe(
            root,
            { attributes: true, attributeFilter: ['data-mode'] }
          );
        } catch (_) {}
      })();
    </script>
    <BaseHead
      title={title}
      description={description}
      lang={lang}
      canonicalUrl={canonicalUrl}
      alternateJa={alternateJa}
      alternateEn={alternateEn}
      ogType={ogType}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      author={author}
      noindex={noindex}
      ogImage={ogImage}
      breadcrumbs={breadcrumbs}
      structuredData={structuredData}
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css" integrity="sha384-zh0CIslj+VczCZtlzBcjt5ppRcsAmDnRem7ESsYwWwg3m/OaJ2l4x7YBZl9Kxxib" crossorigin="anonymous">
  </head>
  <body>
    <Header lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
