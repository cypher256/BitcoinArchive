---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryCard from '../../components/EntryCard.astro';
import { useTranslations, getDisplayEntries, absoluteUrl } from '../../i18n/utils';
import { buildThreadInfo, collapseThreads, resolveThreadId } from '../../data/threads';

export async function getStaticPaths() {
  const { getDisplayEntries } = await import('../../i18n/utils');
  const entries = await getDisplayEntries('en');
  const types = [...new Set(entries.map((e) => e.data.type))];
  const jaEntries = await getDisplayEntries('ja');
  const jaTypes = new Set(jaEntries.map((e) => e.data.type));
  return types.map((type) => ({
    params: { type },
    props: { type, hasJa: jaTypes.has(type) },
  }));
}

const lang = 'en';
const t = useTranslations(lang);
const { type, hasJa } = Astro.props;
const entries = await getDisplayEntries(lang);
const { threadCounts, threadStarters, threadTitles } = buildThreadInfo(entries, lang);
const filtered = entries.filter((e) => e.data.type === type);
const displayEntries = collapseThreads(filtered, threadCounts, threadStarters).reverse();
const typeLabel = t(`type.${type}` as any) || type;

const pageDescription = `${typeLabel} entries — Satoshi Nakamoto and early Bitcoin contributors' communications captured in this format, with original sources preserved.`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `${typeLabel} - ${t('site.title')}`,
  "url": absoluteUrl(`/types/${type}/`, lang),
  "description": pageDescription,
  "inLanguage": lang,
  "mainEntity": {
    "@type": "ItemList",
    "name": typeLabel,
    "numberOfItems": displayEntries.length,
    "itemListOrder": "https://schema.org/ItemListOrderDescending",
    "itemListElement": displayEntries.slice(0, 25).map((entry: any, index: number) => {
      const tid = resolveThreadId(entry);
      const msgCount = tid ? threadCounts.get(tid) || 0 : 0;
      const isThread = msgCount >= 2;
      const itemUrl = isThread
        ? absoluteUrl(`/entries/threads/${tid}/`, lang)
        : absoluteUrl(`/entries/${entry.id}/`, lang);
      const itemName = isThread
        ? (threadTitles.get(tid!) || entry.data.title)
        : entry.data.title;
      return {
        "@type": "ListItem",
        "position": index + 1,
        "url": itemUrl,
        "name": itemName,
      };
    }),
  },
};
---

<BaseLayout
  title={`${typeLabel} - ${t('site.title')}`}
  description={pageDescription}
  lang={lang}
  alternateJa={hasJa ? absoluteUrl(`/types/${type}/`, 'ja') : undefined}
  structuredData={structuredData}
>
  <div class="container">
    <h1>{typeLabel}</h1>
    <p class="page-lead">Entries of this type, gathered from across the archive. Use the type axis to compare communication formats over time.</p>
    <p class="entry-count">{displayEntries.length} entries</p>
    {displayEntries.map((entry) => {
      const tid = resolveThreadId(entry);
      const msgCount = tid ? threadCounts.get(tid) || 0 : 0;
      const isThread = msgCount >= 2;
      return (
        <EntryCard
          id={entry.id}
          title={isThread ? threadTitles.get(tid!) || entry.data.title : entry.data.title}
          date={entry.data.date}
          author={entry.data.author}
          source={entry.data.source}
          description={entry.data.description}
          isSatoshi={entry.data.isSatoshi}
          lang={lang}
          threadId={isThread ? tid : undefined}
          threadCount={isThread ? msgCount : undefined}
          participants={entry.data.participants}
          entryType={entry.data.type}
        />
      );
    })}
  </div>
</BaseLayout>

<style>
  h1 { margin-bottom: 0.25rem; }
  .page-lead {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0 0 0.75rem 0;
    max-width: 70ch;
  }
  .entry-count {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: 0;
  }
</style>
