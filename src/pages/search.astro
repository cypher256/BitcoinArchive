---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations, absoluteUrl } from '../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title={`${t('nav.search')} - ${t('site.title')}`}
  description={t('search.description')}
  lang={lang}
  alternateJa={absoluteUrl('/search/', 'ja')}
  noindex={true}
>
  <div class="container-wide">
    <h1>{t('nav.search')}</h1>
    <div id="searchbox"></div>
    <div id="stats"></div>
    <div id="hits"></div>
    <div id="pagination"></div>
  </div>
</BaseLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/algoliasearch@4.24.0/dist/algoliasearch-lite.umd.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/instantsearch.js@4.75.6/dist/instantsearch.production.min.js"></script>

<style>
  /* Search page CSS. The Algolia satellite-theme CDN bundle was dropped
     here so InstantSearch's `.ais-*` widgets pick up our `data-mode`
     palette directly — no `!important` overrides needed because no
     external stylesheet is fighting these rules. The rules below
     provide every visual cue that satellite-theme used to handle
     (form border, input focus, hits list, pagination chips, hit
     highlight color), all sourced from `--color-*` tokens.
     `.ais-*` and `.hit-*` selectors must use `:global(...)` because
     both InstantSearch (`.ais-*` in its widget DOM) and the
     `templates.item` JS string template (`.hit-*` for the hit
     contents) build elements at runtime — those elements never
     receive the `data-astro-cid-*` attribute that Astro's scoped CSS
     keys on, so unscoped `:global(...)` selectors are required for
     the rules to match. Plain `#searchbox` / `#stats` containers
     are written directly in the .astro template above, so they pick
     up the scoped attribute and don't need `:global(...)`. */
  #searchbox { margin: 1rem 0; }
  #stats {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }
  :global(.hit-item) {
    padding: 1.25rem 0;
    /* `--color-divider` (= `--color-border`) is intentionally faint
       (alpha 0.08–0.10) for prose hairlines — far too subtle to
       separate list items. Use `--color-text-muted` directly so the
       divider is obviously visible in both light and dark. */
    border-bottom: 1px solid var(--color-text-muted);
  }
  :global(.hit-item:last-child) {
    border-bottom: none;
  }
  :global(.hit-item a) {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  :global(.hit-item a:hover) { background: var(--color-bg-alt); }
  :global(.hit-title) {
    font-size: 1.1rem;
    font-weight: bold;
    color: var(--color-link);
    margin-bottom: 0.25rem;
  }
  :global(.hit-meta) {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }
  :global(.hit-meta .satoshi) {
    color: var(--color-satoshi);
    font-weight: bold;
  }
  :global(.hit-snippet) { font-size: 0.9rem; color: var(--color-text); }
  :global(.hit-snippet mark),
  :global(.hit-title mark) {
    background: var(--color-accent-bg);
    color: inherit;
    padding: 0 2px;
  }

  /* InstantSearch widget structure. With satellite-theme dropped,
     these supply the only structural styles for the search form,
     hits list, and pagination — no external CSS to fight, so no
     `!important` is needed.
     `.ais-SearchBox` and `.ais-SearchBox-form` need `width: 100%`
     so the form fills the parent container — without it the form
     shrinks to its content width and the input collapses to its
     placeholder length. `.ais-SearchBox-input` needs `min-width: 0`
     so the flex child can actually shrink below its content size
     when the form is narrow. */
  :global(.ais-SearchBox) {
    width: 100%;
    margin: 0;
  }
  :global(.ais-SearchBox-form) {
    display: flex;
    align-items: center;
    width: 100%;
    background: var(--color-bg);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.5rem 0.75rem;
  }
  :global(.ais-SearchBox-input) {
    flex: 1 1 auto;
    min-width: 0;
    background: transparent;
    color: var(--color-text);
    border: none;
    outline: none;
    font: inherit;
    line-height: 1.5;
    padding: 0;
  }
  :global(.ais-SearchBox-input::placeholder) {
    color: var(--color-text-muted);
    opacity: 1;
  }
  :global(.ais-SearchBox-submit),
  :global(.ais-SearchBox-reset) {
    flex: 0 0 auto;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0 0.25rem;
    display: flex;
    align-items: center;
    color: var(--color-text-muted);
  }
  :global(.ais-SearchBox-submitIcon),
  :global(.ais-SearchBox-resetIcon) {
    width: 14px;
    height: 14px;
    fill: currentColor;
  }
  /* Algolia emits a loading-indicator element by default; we don't
     surface it (results render fast enough that the UI churn isn't
     worth showing), so hide it instead of adding a spinner. */
  :global(.ais-SearchBox-loadingIndicator) {
    display: none;
  }
  :global(.ais-Hits-list) {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  :global(.ais-Hits-item) {
    padding: 0;
    margin: 0;
  }
  :global(.ais-Pagination-list) {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    padding: 1rem 0;
    justify-content: center;
  }
  :global(.ais-Pagination-link) {
    color: var(--color-link);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.25em 0.6em;
    border-radius: 3px;
    text-decoration: none;
  }
  :global(.ais-Pagination-link:hover) {
    color: var(--color-link-hover);
    background: var(--color-bg-alt);
  }
  :global(.ais-Pagination-item--disabled .ais-Pagination-link) {
    color: var(--color-text-muted);
    opacity: 0.6;
  }
  :global(.ais-Pagination-item--selected .ais-Pagination-link) {
    font-weight: bold;
    color: var(--color-bg);
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  :global(.ais-Highlight-highlighted),
  :global(.ais-Snippet-highlighted) {
    background: var(--color-accent-bg);
    color: inherit;
    font-style: normal;
  }
</style>

<script is:inline define:vars={{ basePath }}>
  document.addEventListener('DOMContentLoaded', function() {
    var searchClient = algoliasearch('FI2GZVF3TY', 'c0328bda37db1cc886aacffb2aed5425');

    var urlParams = new URLSearchParams(window.location.search);
    var initialQuery = urlParams.get('q') || '';

    var search = instantsearch({
      indexName: 'bitcoin_archive_en',
      searchClient: searchClient,
      initialUiState: initialQuery ? {
        bitcoin_archive_en: { query: initialQuery },
      } : undefined,
    });

    search.addWidgets([
      instantsearch.widgets.searchBox({
        container: '#searchbox',
        placeholder: 'Search...',
        autofocus: true,
      }),
      instantsearch.widgets.stats({
        container: '#stats',
        templates: {
          text: function(data) {
            return data.nbHits + ' results (' + data.processingTimeMS + 'ms)';
          },
        },
      }),
      instantsearch.widgets.hits({
        container: '#hits',
        templates: {
          item: function(hit) {
            // Color the author only when the author actually is Satoshi.
            // The hit.isSatoshi flag marks entries about/by Satoshi,
            // which for derivative types (analysis/biography) is true
            // even though the author is Bitcoin Institute. Same logic
            // as EntryCard/EntryMeta.
            var isSatoshiAuthor = hit.author
              && hit.author.toLowerCase() === 'satoshi nakamoto';
            var author = isSatoshiAuthor
              ? '<span class="satoshi">' + hit.author + '</span>'
              : '<span>' + hit.author + '</span>';
            var date = hit.date
              ? ' · ' + new Date(hit.date).toLocaleDateString('en-US')
              : '';
            var type = hit.type ? ' · ' + hit.type : '';
            var title = instantsearch.highlight({ attribute: 'title', hit: hit });
            var snippet = instantsearch.snippet({ attribute: 'body', hit: hit });
            return '<div class="hit-item"><a href="' + basePath + hit.url + '">'
              + '<div class="hit-title">' + title + '</div>'
              + '<div class="hit-meta">' + author + date + type + '</div>'
              + '<div class="hit-snippet">' + snippet + '</div>'
              + '</a></div>';
          },
          empty: function() { return '<p>No results found</p>'; },
        },
      }),
      instantsearch.widgets.pagination({
        container: '#pagination',
      }),
    ]);

    search.start();
  });
</script>
