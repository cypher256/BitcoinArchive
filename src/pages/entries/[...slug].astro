---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryMeta from '../../components/EntryMeta.astro';
import SourceCitation from '../../components/SourceCitation.astro';
import AutoLinkNames from '../../components/AutoLinkNames.astro';
import RelatedEntries from '../../components/RelatedEntries.astro';
import SatoshiCodeAnalysis from '../../components/SatoshiCodeAnalysis.astro';
import { getCollection, render } from 'astro:content';
import { useTranslations, formatDate, localePath, absoluteUrl } from '../../i18n/utils';
import { resolveThreadId } from '../../data/threads';

export async function getStaticPaths() {
  const entries = await getCollection('entries');
  const jaEntries = await getCollection('entries_ja');
  const jaIds = new Set(jaEntries.filter((e) => e.data.type !== 'biography').map((e) => e.id));
  return entries.filter((e) => e.data.type !== 'biography').map((entry) => ({
    params: { slug: entry.id },
    props: { entry, hasJa: jaIds.has(entry.id) },
  }));
}

const lang = 'en';
const t = useTranslations(lang);
const { entry, hasJa } = Astro.props;
const { Content } = await render(entry);

const allEntries = await getCollection('entries');
const sorted = allEntries.filter((e) => e.data.type !== 'biography').sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const currentIndex = sorted.findIndex((e) => e.id === entry.id);
const prev = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const next = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

const threadId = resolveThreadId(entry);
const threadMessages = threadId
  ? allEntries.filter((e) => resolveThreadId(e) === threadId).length
  : 0;
const breadcrumbs = [
  { name: t('nav.home'), url: localePath('/', lang) },
  { name: t('nav.entries'), url: localePath('/entries/', lang) },
  { name: entry.data.title, url: localePath(`/entries/${entry.id}/`, lang) },
];
---

<BaseLayout
  title={`${entry.data.title} - ${t('site.title')}`}
  description={entry.data.description}
  lang={lang}
  alternateJa={hasJa ? absoluteUrl(`/entries/${entry.id}/`, 'ja') : undefined}
  ogType="article"
  publishedTime={entry.data.date}
  author={entry.data.author}
  ogImage={`/og/${entry.id}.png`}
  breadcrumbs={breadcrumbs}
>
  <article class="container">
    <nav class="entry-nav entry-nav-top">
      {prev && (
        <a href={localePath(`/entries/${prev.id}/`, lang)} class="nav-prev">
          &larr; {prev.data.title}
        </a>
      )}
      {next && (
        <a href={localePath(`/entries/${next.id}/`, lang)} class="nav-next">
          {next.data.title} &rarr;
        </a>
      )}
    </nav>
    <header class="entry-header">
      <h1>{entry.data.title}</h1>
      <EntryMeta
        date={entry.data.date}
        author={entry.data.author}
        entryType={entry.data.type}
        source={entry.data.source}
        sourceUrl={entry.data.sourceUrl}
        isSatoshi={entry.data.isSatoshi}
        lang={lang}
        participants={entry.data.participants}
        tags={entry.data.tags}
      />
    </header>

    {entry.data.editorNote && (
      <p class="editor-note">{entry.data.editorNote}</p>
    )}

    <div class:list={["entry-content", { "conversation-thread": entry.data.isConversation }]}>
      <Content />
    </div>

    {entry.data.type === 'analysis' && entry.id.includes('satoshi-code') && (
      <SatoshiCodeAnalysis lang={lang} />
    )}

    {threadId && threadMessages >= 2 && (
      <div class="thread-banner">
        <a href={localePath(`/entries/threads/${threadId}/`, lang)}>
          View full thread ({threadMessages} messages) &rarr;
        </a>
      </div>
    )}

    <RelatedEntries lang={lang} relatedIds={entry.data.relatedEntries ?? []} />

    <SourceCitation
      sourceUrl={entry.data.sourceUrl}
      secondarySources={entry.data.secondarySources}
      pdfMetadata={entry.data.pdfMetadata}
      lang={lang}
    />

    <nav class="entry-nav">
      {prev && (
        <a href={localePath(`/entries/${prev.id}/`, lang)} class="nav-prev">
          &larr; {prev.data.title}
        </a>
      )}
      {next && (
        <a href={localePath(`/entries/${next.id}/`, lang)} class="nav-next">
          {next.data.title} &rarr;
        </a>
      )}
    </nav>
  </article>
  <AutoLinkNames lang={lang} selectors=".entry-content, .satoshi-analysis" />
</BaseLayout>

<style>
  .entry-header {
    padding-top: 2rem;
    margin-bottom: 2rem;
  }
  .entry-header h1 {
    margin: 0 0 0.75rem;
    font-size: 2rem;
  }
  .editor-note {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0 0 2rem;
    padding: 0.75rem 1rem;
    border-left: 3px solid var(--color-border);
    background: var(--color-bg-alt);
  }
  .entry-content {
    line-height: 1.8;
  }
  .entry-content :global(blockquote) {
    margin: 1.5em 0;
    padding: 0.75em 1.25em;
    border-left: 3px solid var(--color-accent);
    background: var(--color-bg-alt);
  }
  .entry-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-heading);
    font-size: 0.9rem;
  }
  .nav-prev, .nav-next {
    max-width: 45%;
  }
  .entry-nav-top {
    margin-top: 0;
    padding-top: 1rem;
    border-top: none;
    margin-bottom: 0;
  }
  .nav-next {
    margin-left: auto;
    text-align: right;
  }
  .thread-banner {
    margin: 1.5rem 0;
    padding: 0.75rem 1rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 4px 4px 0;
    font-family: var(--font-heading);
    font-size: 0.9rem;
  }
  .thread-banner a {
    font-weight: 600;
  }
</style>
