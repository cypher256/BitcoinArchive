---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryCard from '../../components/EntryCard.astro';
import { useTranslations, getDisplayEntries, absoluteUrl } from '../../i18n/utils';
import { buildThreadInfo, collapseThreads, resolveThreadId } from '../../data/threads';

export async function getStaticPaths() {
  const { getDisplayEntries } = await import('../../i18n/utils');
  const entries = await getDisplayEntries('en');
  const sources = [...new Set(entries.map((e) => e.data.source))];
  const jaEntries = await getDisplayEntries('ja');
  const jaSources = new Set(jaEntries.map((e) => e.data.source));
  return sources.map((source) => ({
    params: { source },
    props: { source, hasJa: jaSources.has(source) },
  }));
}

const lang = 'en';
const t = useTranslations(lang);
const { source, hasJa } = Astro.props;
const entries = await getDisplayEntries(lang);
const { threadCounts, threadStarters, threadTitles } = buildThreadInfo(entries, lang);
const filtered = entries.filter((e) => e.data.source === source);
const displayEntries = collapseThreads(filtered, threadCounts, threadStarters).reverse();
const sourceLabel = t(`source.${source}` as any) || source;

const pageDescription = `Archive of communications originating from ${sourceLabel} — Satoshi Nakamoto and early Bitcoin contributors' forum posts, emails, and technical discussions, with original sources preserved.`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `${sourceLabel} - ${t('site.title')}`,
  "url": absoluteUrl(`/sources/${source}/`, lang),
  "description": pageDescription,
  "inLanguage": lang,
  "mainEntity": {
    "@type": "ItemList",
    "name": sourceLabel,
    "numberOfItems": displayEntries.length,
    "itemListOrder": "https://schema.org/ItemListOrderDescending",
    "itemListElement": displayEntries.slice(0, 25).map((entry: any, index: number) => {
      const tid = resolveThreadId(entry);
      const msgCount = tid ? threadCounts.get(tid) || 0 : 0;
      const isThread = msgCount >= 2;
      const itemUrl = isThread
        ? absoluteUrl(`/entries/threads/${tid}/`, lang)
        : absoluteUrl(`/entries/${entry.id}/`, lang);
      const itemName = isThread
        ? (threadTitles.get(tid!) || entry.data.title)
        : entry.data.title;
      return {
        "@type": "ListItem",
        "position": index + 1,
        "url": itemUrl,
        "name": itemName,
      };
    }),
  },
};
---

<BaseLayout
  title={`${sourceLabel} - ${t('site.title')}`}
  description={pageDescription}
  lang={lang}
  alternateJa={hasJa ? absoluteUrl(`/sources/${source}/`, 'ja') : undefined}
  structuredData={structuredData}
>
  <div class="container-wide">
    <h1>{sourceLabel}</h1>
    <p class="page-lead">Entries originating from this channel. The source axis lets you trace the venues Satoshi and contemporaries used over time.</p>
    <p class="entry-count">{displayEntries.length} entries</p>
    {displayEntries.map((entry) => {
      const tid = resolveThreadId(entry);
      const msgCount = tid ? threadCounts.get(tid) || 0 : 0;
      const isThread = msgCount >= 2;
      return (
        <EntryCard
          id={entry.id}
          title={isThread ? threadTitles.get(tid!) || entry.data.title : entry.data.title}
          date={entry.data.date}
          author={entry.data.author}
          source={entry.data.source}
          description={entry.data.description}
          isSatoshi={entry.data.isSatoshi}
          lang={lang}
          threadId={isThread ? tid : undefined}
          threadCount={isThread ? msgCount : undefined}
          participants={entry.data.participants}
        />
      );
    })}
  </div>
</BaseLayout>

<style>
  h1 { margin-bottom: 0.25rem; }
  .page-lead {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0 0 0.75rem 0;
  }
  .entry-count {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: 0;
  }
</style>
