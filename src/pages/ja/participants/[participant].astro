---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EntryCard from '../../../components/EntryCard.astro';
import { render } from 'astro:content';
import { useTranslations, getEntries, getBiographyForParticipant, localePath } from '../../../i18n/utils';

export async function getStaticPaths() {
  const { getEntries, getDisplayEntries } = await import('../../../i18n/utils');
  const entries = await getEntries('ja');
  const displayEntries = await getDisplayEntries('en');
  const slugs = new Set<string>();
  const nameMap = new Map<string, string>();
  for (const entry of entries) {
    for (const p of entry.data.participants) {
      slugs.add(p.slug);
      nameMap.set(p.slug, p.name);
    }
  }
  const countMap = new Map<string, number>();
  for (const entry of displayEntries) {
    for (const p of entry.data.participants) {
      countMap.set(p.slug, (countMap.get(p.slug) || 0) + 1);
    }
  }
  const sorted = Array.from(slugs).sort((a, b) => (countMap.get(b) || 0) - (countMap.get(a) || 0));
  return sorted.map((slug, i) => ({
    params: { participant: slug },
    props: {
      participantSlug: slug,
      participantName: nameMap.get(slug)!,
      prevParticipant: i > 0 ? { slug: sorted[i - 1], name: nameMap.get(sorted[i - 1])! } : null,
      nextParticipant: i < sorted.length - 1 ? { slug: sorted[i + 1], name: nameMap.get(sorted[i + 1])! } : null,
    },
  }));
}

const lang = 'ja';
const t = useTranslations(lang);
const { participantSlug, participantName, prevParticipant, nextParticipant } = Astro.props;
const entries = await getEntries(lang);
const filtered = entries.filter((e) =>
  e.data.participants.some((p) => p.slug === participantSlug)
);

const biographyEntry = await getBiographyForParticipant(lang, participantSlug);
const biographyContent = biographyEntry ? await render(biographyEntry) : null;
const displayEntries = filtered.filter((e) => e.data.aftermathType !== 'biography');
const lifeDatesMatch = biographyEntry?.data.title.match(/[（(]([^)）]+)[)）]/);
const lifeDates = lifeDatesMatch ? lifeDatesMatch[0] : null;
const biographyDescription = biographyEntry?.data.description?.replace(/^[^：:]+[：:]\s*/, '') ?? '';
---

<BaseLayout
  title={`${participantName} - ${t('site.title')}`}
  description={biographyEntry?.data.description ?? `${participantName}に関するエントリー一覧`}
  lang={lang}
  alternateEn={`https://cypher256.github.io/BitcoinArchive/participants/${participantSlug}/`}
>
  <div class="container">
    <nav class="participant-nav participant-nav-top">
      {prevParticipant ? (
        <a href={localePath(`/participants/${prevParticipant.slug}/`, lang)} class="nav-prev">&larr; {prevParticipant.name}</a>
      ) : <span />}
      {nextParticipant ? (
        <a href={localePath(`/participants/${nextParticipant.slug}/`, lang)} class="nav-next">{nextParticipant.name} &rarr;</a>
      ) : <span />}
    </nav>
    <h1>{participantName}{lifeDates && <span class="life-dates"> {lifeDates}</span>}</h1>

    {biographyContent && (
      <section class="biography-section">
        <p class="biography-description">{biographyDescription}</p>
        <div class="biography-content">
          <biographyContent.Content />
        </div>
      </section>
    )}

    {biographyContent ? (
      <h2 class="entries-heading">{t('participant.relatedEntries' as any)}</h2>
    ) : null}
    <p class="entry-count">{displayEntries.length} エントリー</p>
    {displayEntries.map((entry) => (
      <EntryCard
        id={entry.id}
        title={entry.data.title}
        date={entry.data.date}
        author={entry.data.author}
        source={entry.data.source}
        description={entry.data.description}
        isSatoshi={entry.data.isSatoshi}
        lang={lang}
        participants={entry.data.participants}
      />
    ))}

    <nav class="participant-nav">
      {prevParticipant ? (
        <a href={localePath(`/participants/${prevParticipant.slug}/`, lang)} class="nav-prev">&larr; {prevParticipant.name}</a>
      ) : <span />}
      {nextParticipant ? (
        <a href={localePath(`/participants/${nextParticipant.slug}/`, lang)} class="nav-next">{nextParticipant.name} &rarr;</a>
      ) : <span />}
    </nav>
  </div>
</BaseLayout>

<style>
  h1 { margin-bottom: 0.25rem; }
  .life-dates {
    font-weight: normal;
    font-size: 0.6em;
    color: var(--color-text-muted);
  }
  .biography-section {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .biography-description {
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }
  .biography-content {
    line-height: 1.8;
  }
  .biography-content :global(p:first-child) {
    margin-top: 0;
  }
  .entries-heading {
    margin-top: 0;
    margin-bottom: 0.25rem;
  }
  .entry-count {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: 0;
  }
  .participant-nav {
    display: flex;
    justify-content: space-between;
    margin-top: 2.5rem;
    padding-top: 0;
    font-family: var(--font-heading);
    font-size: 0.9rem;
  }
  .participant-nav-top {
    margin-top: 1.5rem;
    padding-top: 0;
    border-top: none;
    margin-bottom: 0.5rem;
  }
  .nav-next {
    margin-left: auto;
  }
</style>
