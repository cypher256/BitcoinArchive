---
import { formatDate, localePath, useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Participant {
  name: string;
  slug: string;
}

interface Props {
  id: string;
  title: string;
  date: Date;
  author: string;
  source: string;
  description: string;
  isSatoshi: boolean;
  lang: Lang;
  threadId?: string;
  threadCount?: number;
  participants?: Participant[];
  aftermathType?: string;
  createdAt?: string;
  updatedAt?: string;
}

const { id, title, date, author, source, description, isSatoshi, lang, threadId, threadCount, participants = [], aftermathType, createdAt, updatedAt } = Astro.props;
const isBiography = aftermathType === 'biography';
const t = useTranslations(lang);
const sourceLabel = t(`source.${source}` as any) || source;
const href = threadId
  ? localePath(`/entries/threads/${threadId}/`, lang)
  : localePath(`/entries/${id}/`, lang);
const otherParticipants = participants.filter((p) => p.name !== author);
const authorParticipant = participants.find((p) => p.name === author);
---

<article
  class:list={["entry-card", { "entry-card-thread": !!threadId }]}
  data-date={date.toISOString()}
  data-created={createdAt ?? ''}
  data-updated={updatedAt ?? ''}
>
  <a href={href} class="card-link">
    <div class="card-header">
      <time datetime={date.toISOString()}>{formatDate(date, lang)}</time>
      <span class="source-badge">{sourceLabel}</span>
      {threadCount && threadCount >= 2 && (
        <span class="thread-badge">{threadCount} messages</span>
      )}
      {isBiography && (
        <span class="biography-badge">{t('entry.biography' as any)}</span>
      )}
    </div>
    <h3 class="card-title">{title}</h3>
  </a>
  <p class="card-author">
    {authorParticipant ? (
      <a href={localePath(`/participants/${authorParticipant.slug}/`, lang)} class:list={["author-link", { satoshi: isSatoshi }]}>{author}</a>
    ) : (
      <span class:list={[{ satoshi: isSatoshi }]}>{author}</span>
    )}
    {otherParticipants.length > 0 && (
      <span class="participants-with">
        &harr; {otherParticipants.map((p, i) => (
          <><a href={localePath(`/participants/${p.slug}/`, lang)} class="participant-link">{p.name}</a>{i < otherParticipants.length - 1 && ', '}</>
        ))}
      </span>
    )}
  </p>
  <a href={href} class="card-link">
    <p class="card-description">{description}</p>
  </a>
</article>

<style>
  .entry-card {
    border-bottom: 1px solid var(--color-border);
    padding: 1.25rem 0;
  }
  .entry-card:last-child {
    border-bottom: none;
  }
  .entry-card-thread {
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
  }
  .card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .card-link:hover .card-title {
    color: var(--color-link);
  }
  .card-link:hover {
    text-decoration: none;
  }
  .card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.3rem;
  }
  .source-badge {
    display: inline-block;
    padding: 0.1em 0.5em;
    background: var(--color-source-bg);
    border-radius: 3px;
  }
  .thread-badge {
    display: inline-block;
    padding: 0.1em 0.5em;
    background: var(--color-accent);
    color: #fff;
    border-radius: 3px;
    font-weight: 600;
    font-size: 0.75rem;
  }
  .biography-badge {
    display: inline-block;
    padding: 0.1em 0.5em;
    background: var(--color-text-muted);
    color: #fff;
    border-radius: 3px;
    font-weight: 600;
    font-size: 0.75rem;
    opacity: 0.7;
  }
  .card-title {
    margin: 0 0 0.25rem;
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.4;
  }
  .card-author {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0 0 0.3rem;
  }
  .satoshi {
    color: var(--color-satoshi);
    font-weight: 600;
  }
  .author-link {
    text-decoration: none;
    color: var(--color-text-muted);
  }
  .author-link:hover {
    text-decoration: underline;
  }
  .author-link.satoshi {
    color: var(--color-satoshi);
    font-weight: 600;
  }
  .participant-link {
    text-decoration: none;
    color: var(--color-text-muted);
  }
  .participant-link:hover {
    text-decoration: underline;
  }
  .participants-with {
    color: var(--color-text-muted);
    font-weight: 400;
  }
  .card-description {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }
</style>
