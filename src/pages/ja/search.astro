---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, absoluteUrl } from '../../i18n/utils';

const lang = 'ja';
const t = useTranslations(lang);
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title={`${t('nav.search')} - ${t('site.title')}`}
  description={t('search.description')}
  lang={lang}
  alternateEn={absoluteUrl('/search/', 'en')}
  noindex={true}
>
  <div class="container-wide">
    <h1>{t('nav.search')}</h1>
    <div id="searchbox"></div>
    <div id="stats"></div>
    <div id="hits"></div>
    <div id="pagination"></div>
  </div>
</BaseLayout>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/instantsearch.css@8/themes/satellite-min.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/algoliasearch@4.24.0/dist/algoliasearch-lite.umd.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/instantsearch.js@4.75.6/dist/instantsearch.production.min.js"></script>

<style>
  /* The Algolia satellite theme bundles hardcoded `#fff` panel
     surfaces, `#5468ff` purple links, light borders, and a light
     focus ring. Phase 6's token-based palette has to override
     every one of those paths so the search page tracks
     `data-mode` like the rest of the site (header / footer /
     entry pages). All hit / pagination / searchbox surfaces
     resolve to `var(--color-bg)` + `var(--color-text)` +
     `var(--color-border)` / `var(--color-link)` so light + dark
     both render with full contrast. */
  .container { max-width: 800px; margin: 0 auto; padding: 1rem; }
  #searchbox { margin: 1rem 0; }
  #stats {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }
  .hit-item {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-divider);
  }
  .hit-item a {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .hit-item a:hover { background: var(--color-bg-alt); }
  .hit-title {
    font-size: 1.1rem;
    font-weight: bold;
    color: var(--color-link);
    margin-bottom: 0.25rem;
  }
  .hit-meta {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }
  .hit-meta .satoshi {
    color: var(--color-satoshi);
    font-weight: bold;
  }
  .hit-snippet { font-size: 0.9rem; color: var(--color-text); }
  .hit-snippet mark, .hit-title mark {
    background: var(--color-accent-bg);
    color: inherit;
    padding: 0 2px;
  }
  .hit-item, .hit-item a, .hit-item a * {
    color: var(--color-text);
  }
  .hit-item a .hit-title { color: var(--color-link); }
  .hit-item a .hit-meta { color: var(--color-text-muted); }
  .hit-item a .hit-snippet { color: var(--color-text); }
  /* Algolia satellite theme injects #fff panels on outer widgets.
     Force transparent so the page bg (Modern A light/dark) shows. */
  :global(.ais-Hits),
  :global(.ais-Hits-list),
  :global(.ais-Hits-item),
  :global(.ais-SearchBox),
  :global(.ais-Pagination),
  :global(.ais-Stats),
  :global(.ais-PoweredBy),
  :global(.ais-InstantSearch) {
    background: transparent !important;
    box-shadow: none !important;
  }

  /* Algolia InstantSearch widget overrides. The satellite CDN
     theme injects `#fff` / `#23263b` panels, `#5468ff` purple
     links, and light focus rings — all hardcoded. Re-skin to
     tokens so dark mode reads correctly. Selectors are scoped
     to `.ais-` widgets only (= no leakage onto the rest of the
     page). */
  :global(.ais-SearchBox-form) {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    box-shadow: none;
  }
  :global(.ais-SearchBox-input) {
    background: var(--color-bg);
    color: var(--color-text);
  }
  :global(.ais-SearchBox-input::placeholder) {
    color: var(--color-text-muted);
    opacity: 1;
  }
  :global(.ais-SearchBox-input:focus) {
    background: var(--color-bg);
    color: var(--color-text);
  }
  :global(.ais-SearchBox-submitIcon),
  :global(.ais-SearchBox-resetIcon) {
    fill: var(--color-text-muted);
  }
  :global(.ais-Hits-list) {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  :global(.ais-Hits-item) {
    background: transparent;
    box-shadow: none;
    padding: 0;
    margin: 0;
    border: none;
  }
  :global(.ais-Pagination-list) {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    padding: 1rem 0;
    justify-content: center;
  }
  :global(.ais-Pagination-link) {
    color: var(--color-link);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.25em 0.6em;
    border-radius: 3px;
    text-decoration: none;
  }
  :global(.ais-Pagination-link:hover) {
    color: var(--color-link-hover);
    background: var(--color-bg-alt);
  }
  :global(.ais-Pagination-item--disabled .ais-Pagination-link) {
    color: var(--color-text-muted);
    opacity: 0.6;
  }
  :global(.ais-Pagination-item--selected .ais-Pagination-link) {
    font-weight: bold;
    color: var(--color-bg);
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  :global(.ais-Highlight-highlighted),
  :global(.ais-Snippet-highlighted) {
    background: var(--color-accent-bg);
    color: inherit;
    font-style: normal;
  }
</style>

<script is:inline define:vars={{ basePath }}>
  document.addEventListener('DOMContentLoaded', function() {
    var searchClient = algoliasearch('FI2GZVF3TY', 'c0328bda37db1cc886aacffb2aed5425');

    var urlParams = new URLSearchParams(window.location.search);
    var initialQuery = urlParams.get('q') || '';

    var search = instantsearch({
      indexName: 'bitcoin_archive_ja',
      searchClient: searchClient,
      initialUiState: initialQuery ? {
        bitcoin_archive_ja: { query: initialQuery },
      } : undefined,
    });

    search.addWidgets([
      instantsearch.widgets.searchBox({
        container: '#searchbox',
        placeholder: '検索...',
        autofocus: true,
      }),
      instantsearch.widgets.stats({
        container: '#stats',
        templates: {
          text: function(data) {
            return data.nbHits + '件の検索結果（' + data.processingTimeMS + 'ms）';
          },
        },
      }),
      instantsearch.widgets.hits({
        container: '#hits',
        templates: {
          item: function(hit, bindEvent) {
            // Color the author only when the author actually is Satoshi.
            // Same logic as EntryCard / EntryMeta / EN search — see
            // commit 0efcc45e for the full reasoning. The hit.isSatoshi
            // flag marks entries about/by Satoshi, which for derivative
            // types (analysis/biography) is true even though the author
            // is Bitcoin Institute.
            var isSatoshiAuthor = hit.author
              && hit.author.toLowerCase() === 'satoshi nakamoto';
            var author = isSatoshiAuthor
              ? '<span class="satoshi">' + hit.author + '</span>'
              : '<span>' + hit.author + '</span>';
            var date = hit.date
              ? ' · ' + new Date(hit.date).toLocaleDateString('ja-JP')
              : '';
            var type = hit.type ? ' · ' + hit.type : '';
            var title = instantsearch.highlight({ attribute: 'title', hit: hit });
            var snippet = instantsearch.snippet({ attribute: 'body', hit: hit });
            return '<div class="hit-item"><a href="' + basePath + hit.url + '">'
              + '<div class="hit-title">' + title + '</div>'
              + '<div class="hit-meta">' + author + date + type + '</div>'
              + '<div class="hit-snippet">' + snippet + '</div>'
              + '</a></div>';
          },
          empty: function() { return '<p>検索結果がありません</p>'; },
        },
      }),
      instantsearch.widgets.pagination({
        container: '#pagination',
      }),
    ]);

    search.start();
  });
</script>
