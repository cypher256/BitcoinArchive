---
import { readFileSync, existsSync } from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import { useTranslations, formatDate, localePath, translateParticipantName, findAuthorParticipant, translateTag } from '../i18n/utils';
import { slugifyKeyword } from '../lib/keyword-slug.mjs';
import type { Lang } from '../i18n/ui';

// Backlink-count lookup for `inlineLinkKeywords` display. Loaded once
// per build/dev session from the keyword index produced by
// `scripts/generate-keyword-index.mjs`. The file is regenerated at the
// top of `npm run dev` / `npm run build` / `npm run check`, so the
// counts shown here are always synced to the latest archive content.
//
// Shape: { [locale]: { counts: { [keyword]: entryCount } } }.
// `counts` only includes keywords with ≥1 backlink — absent entries
// imply 0 (and the UI skips the "(N)" suffix in that case).
const __dirname = path.dirname(fileURLToPath(import.meta.url));
const KEYWORD_INDEX_PATH = path.resolve(__dirname, '..', 'data', 'keyword-index.json');
let keywordCounts: Record<string, Record<string, number>> = { en: {}, ja: {} };
if (existsSync(KEYWORD_INDEX_PATH)) {
  try {
    const raw = JSON.parse(readFileSync(KEYWORD_INDEX_PATH, 'utf-8'));
    keywordCounts = {
      en: raw?.en?.counts ?? {},
      ja: raw?.ja?.counts ?? {},
    };
  } catch {
    // Malformed index — fall back to empty counts.
  }
}

interface Participant {
  name: string;
  slug: string;
}

interface Props {
  date: Date;
  author: string;
  entryType: string;
  source: string;
  sourceUrl: string;
  isSatoshi: boolean;
  lang: Lang;
  participants?: Participant[];
  tags?: string[];
  /**
   * Concept keywords this entry claims as definition target. Sourced
   * from `inlineLinkKeywords` frontmatter. Rendered as a "Defines:"
   * row when the entry is editorial (analysis / article — biography
   * is excluded since the page title already names the participant,
   * making the keyword display redundant). Each keyword is plain
   * text (not a link to itself). The actual auto-linking from other
   * entries is handled by `rehype-auto-link-keywords.mjs`.
   */
  inlineLinkKeywords?: string[];
  /**
   * Content last-updated date, derived from git history (see
   * scripts/generate-git-dates.mjs and src/data/git-dates.json).
   * Conceptually distinct from `date`: `date` is the entry's anchor
   * to the historical event it describes, while `updatedAt` is the
   * date of the most recent edit to the entry's source file.
   * Optional — entries without a git-history record (e.g. previews)
   * simply don't show the line.
   */
  updatedAt?: Date;
}

const { date, author, entryType, source, sourceUrl, isSatoshi, lang, participants = [], tags = [], inlineLinkKeywords = [], updatedAt } = Astro.props;
const showDefinesRow = inlineLinkKeywords.length > 0 && (entryType === 'analysis' || entryType === 'article');
const t = useTranslations(lang);
const typeLabel = t(`type.${entryType}` as any) || entryType;
const sourceLabel = t(`source.${source}` as any) || source;
const authorParticipant = findAuthorParticipant(author, participants);
const displayAuthor = translateParticipantName(authorParticipant?.name ?? author, authorParticipant?.slug, lang);

// Color the author name in the Satoshi accent only when the author
// actually is Satoshi. The `isSatoshi` frontmatter flag means "this
// entry is about / by Satoshi" — for derivative types (analysis,
// biography) that flag is true while the author is Bitcoin Institute,
// so it must not drive the author color. Same logic as EntryCard.
const isSatoshiAuthor =
  authorParticipant?.slug === 'satoshi-nakamoto' ||
  author.toLowerCase() === 'satoshi nakamoto';
---

<div class="entry-meta">
  <span class="date-label">{t('entry.event' as any)}</span>
  <time datetime={date.toISOString()}>{formatDate(date, lang)}</time>
  {updatedAt && (
    <>
      <span class="meta-sep">&middot;</span>
      <span class="date-label">{t('entry.updated' as any)}</span>
      <time datetime={updatedAt.toISOString()}>{formatDate(updatedAt, lang)}</time>
    </>
  )}
  <span class="meta-sep">&middot;</span>
  <span class:list={['author', { satoshi: isSatoshiAuthor }]}>{displayAuthor}</span>
  <span class="meta-sep">&middot;</span>
  <a href={localePath(`/types/${entryType}/`, lang)} class="type-badge">{typeLabel}</a>
  <span class="meta-sep">&middot;</span>
  <a href={localePath(`/sources/${source}/`, lang)} class="source-badge">{sourceLabel}</a>
</div>

{participants.length > 0 && (
  <div class="participants-row">
    <span class="participants-label">{lang === 'ja' ? '人物：' : 'Figures:'}</span>
    {participants.map((p, i) => (
      <>
        <a href={localePath(`/participants/${p.slug}/`, lang)} class:list={["participant-link", { satoshi: p.name === 'Satoshi Nakamoto' }]}>{translateParticipantName(p.name, p.slug, lang)}</a>
        {i < participants.length - 1 && <span class="participant-sep">,&nbsp;</span>}
      </>
    ))}
  </div>
)}

{showDefinesRow && (() => {
  // Sort by backlink count descending; 0-count keywords sink to the end.
  // Original frontmatter order acts as tiebreaker (stable sort), so
  // editor-chosen sequence is preserved within equal-count groups.
  const sortedKeywords = inlineLinkKeywords
    .map((kw, originalIndex) => ({
      kw,
      n: keywordCounts[lang]?.[kw] ?? 0,
      originalIndex,
    }))
    .sort((a, b) => b.n - a.n || a.originalIndex - b.originalIndex);
  return (
    <div class="defines-row">
      <span class="defines-label">{lang === 'ja' ? '定義：' : 'Defines:'}</span>
      {sortedKeywords.map(({ kw, n }, i) => {
        const slug = slugifyKeyword(kw);
        return (
          <>
            <a class="defines-keyword" href={localePath(`/keywords/${slug}/`, lang)}>{kw}{n > 0 && <span class="defines-count"> ({n})</span>}</a>
            {i < sortedKeywords.length - 1 && <span class="defines-sep">&middot;</span>}
          </>
        );
      })}
    </div>
  );
})()}

{tags.length > 0 && (
  <div class="tags-row">
    {tags.map((tag) => (
      <a href={localePath(`/tags/${tag}/`, lang)} class="tag-link">{translateTag(tag, lang)}</a>
    ))}
  </div>
)}

<style>
  .entry-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }
  .date-label {
    font-weight: 600;
    margin-right: -0.15rem;
  }
  .meta-sep {
    color: var(--color-border);
  }
  .author.satoshi {
    color: var(--color-satoshi);
    font-weight: 600;
  }
  .type-badge {
    display: inline-block;
    padding: 0.1em 0.5em;
    background: var(--color-accent);
    color: #fff;
    border-radius: 3px;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
  }
  .type-badge:hover {
    opacity: 0.85;
  }
  .source-badge {
    display: inline-block;
    padding: 0.1em 0.5em;
    background: var(--color-source-bg);
    border-radius: 3px;
    font-size: 0.8rem;
    text-decoration: none;
    color: inherit;
  }
  .source-badge:hover {
    opacity: 0.85;
  }
  .participants-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.6rem;
    gap: 0.15rem;
  }
  .participants-label {
    margin-right: 0.3rem;
    font-weight: 600;
  }
  .participant-link {
    text-decoration: none;
    color: var(--color-link);
  }
  .participant-link:hover {
    text-decoration: underline;
  }
  .participant-link.satoshi {
    color: var(--color-satoshi);
    font-weight: 600;
  }
  .participant-sep {
    color: var(--color-text-muted);
  }
  .tags-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    margin-bottom: 1.5rem;
  }
  .tag-link {
    display: inline-block;
    padding: 0.15em 0.55em;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .tag-link:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
    text-decoration: none;
  }
  .defines-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.15rem 0.4rem;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.6rem;
  }
  .defines-label {
    font-weight: 600;
  }
  .defines-keyword {
    color: var(--color-link);
    text-decoration: none;
  }
  .defines-keyword:hover {
    text-decoration: underline;
  }
  .defines-count {
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }
  .defines-sep {
    color: var(--color-border);
  }
</style>
