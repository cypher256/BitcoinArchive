---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryCard from '../../components/EntryCard.astro';
import { useTranslations, getDisplayEntries } from '../../i18n/utils';
import { buildThreadInfo, collapseThreads } from '../../data/threads';

export async function getStaticPaths() {
  const { getDisplayEntries } = await import('../../i18n/utils');
  const entries = await getDisplayEntries('en');
  const tags = new Set<string>();
  for (const entry of entries) {
    for (const tag of entry.data.tags ?? []) {
      tags.add(tag);
    }
  }
  // 日本語側に存在するタグを取得
  const jaEntries = await getDisplayEntries('ja');
  const jaTags = new Set<string>();
  for (const entry of jaEntries) {
    for (const tag of entry.data.tags ?? []) {
      jaTags.add(tag);
    }
  }
  return Array.from(tags).map((tag) => ({
    params: { tag },
    props: { tag, hasJa: jaTags.has(tag) },
  }));
}

const lang = 'en';
const t = useTranslations(lang);
const { tag, hasJa } = Astro.props;
const entries = await getDisplayEntries(lang);
const { threadCounts, threadStarters, threadTitles } = buildThreadInfo(entries, lang);
const filtered = entries.filter((e) => (e.data.tags ?? []).includes(tag));
const displayEntries = collapseThreads(filtered, threadCounts, threadStarters);
---

<BaseLayout
  title={`${tag} - ${t('site.title')}`}
  description={`Entries tagged "${tag}" in the Bitcoin Archive`}
  lang={lang}
  alternateJa={hasJa ? `https://cypher256.github.io/BitcoinArchive/ja/tags/${tag}/` : undefined}
>
  <div class="container">
    <h1>{tag}</h1>
    <p class="entry-count">{displayEntries.length} entries</p>
    {displayEntries.map((entry) => {
      const tid = entry.data.threadId;
      const msgCount = tid ? threadCounts.get(tid) || 0 : 0;
      const isThread = msgCount >= 2;
      return (
        <EntryCard
          id={entry.id}
          title={isThread ? threadTitles.get(tid!) || entry.data.title : entry.data.title}
          date={entry.data.date}
          author={entry.data.author}
          source={entry.data.source}
          description={entry.data.description}
          isSatoshi={entry.data.isSatoshi}
          lang={lang}
          threadId={isThread ? tid : undefined}
          threadCount={isThread ? msgCount : undefined}
          participants={entry.data.participants}
        />
      );
    })}
  </div>
</BaseLayout>

<style>
  h1 { margin-bottom: 0.25rem; }
  .entry-count {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: 0;
  }
</style>
