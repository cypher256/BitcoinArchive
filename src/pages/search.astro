---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations, absoluteUrl } from '../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title={`${t('nav.search')} - ${t('site.title')}`}
  description="Search the Bitcoin Archive"
  lang={lang}
  alternateJa={absoluteUrl('/search/', 'ja')}
  noindex={true}
>
  <div class="container">
    <h1>{t('nav.search')}</h1>
    <div id="search"></div>
  </div>
</BaseLayout>

<link href={`${base}/pagefind/pagefind-ui.css`} rel="stylesheet" />
<script is:inline src={`${base}/pagefind/pagefind-ui.js`}></script>
<script is:inline define:vars={{ searchBase: `${base}/` }}>
  window.addEventListener('DOMContentLoaded', () => {
    new PagefindUI({
      element: '#search',
      showSubResults: true,
      baseUrl: searchBase,
    });
  });
</script>

<style>
  #search {
    margin-top: 1rem;
  }
</style>
