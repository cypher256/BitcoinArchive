---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EntryCard from '../../../components/EntryCard.astro';
import { useTranslations, getDisplayEntries, absoluteUrl } from '../../../i18n/utils';
import { buildThreadInfo, collapseThreads, resolveThreadId } from '../../../data/threads';
import { existsSync, readFileSync } from 'fs';
import { join } from 'path';

const lang = 'ja';
const t = useTranslations(lang);
const jaEntries = await getDisplayEntries(lang);
const enEntries = await getDisplayEntries('en');
const entries = jaEntries.length > 0 ? jaEntries : enEntries;
const { threadCounts, threadStarters, threadTitles } = buildThreadInfo(entries, lang);
const displayEntries = collapseThreads(entries, threadCounts, threadStarters).reverse();

// Load git dates (generated at build time)
const gitDatesPath = join(process.cwd(), 'src/data/git-dates.json');
const gitDates: Record<string, { createdAt: string; updatedAt: string }> = existsSync(gitDatesPath)
  ? JSON.parse(readFileSync(gitDatesPath, 'utf-8'))
  : {};
const hasGitDates = Object.keys(gitDates).length > 0;
const pageDescription = "サトシ・ナカモトと初期ビットコイン貢献者によるコミュニケーションの完全な時系列アーカイブ。フォーラム投稿、メーリングリスト、私信、一次資料を、原典を保持した形で収録。";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `${t('nav.entries')} - ${t('site.title')}`,
  "url": absoluteUrl('/entries/', lang),
  "description": pageDescription,
  "inLanguage": lang,
  "mainEntity": {
    "@type": "ItemList",
    "name": t('nav.entries'),
    "numberOfItems": displayEntries.length,
    "itemListOrder": "https://schema.org/ItemListOrderDescending",
    "itemListElement": displayEntries.slice(0, 25).map((entry: any, index: number) => {
      const tid = resolveThreadId(entry);
      const msgCount = tid ? threadCounts.get(tid) || 0 : 0;
      const isThread = msgCount >= 2;
      const itemUrl = isThread
        ? absoluteUrl(`/entries/threads/${tid}/`, lang)
        : absoluteUrl(`/entries/${entry.id}/`, lang);
      const itemName = isThread
        ? (threadTitles.get(tid!) || entry.data.title)
        : entry.data.title;
      return {
        "@type": "ListItem",
        "position": index + 1,
        "url": itemUrl,
        "name": itemName,
      };
    }),
  },
};
---

<BaseLayout
  title={`${t('nav.entries')} - ${t('site.title')}`}
  description={pageDescription}
  lang={lang}
  alternateEn={absoluteUrl('/entries/', 'en')}
  structuredData={structuredData}
>
  <div class="container-wide">
    <h1>{t('nav.entries')}</h1>
    <p class="page-lead">このアーカイブに収録された全ての一次資料を時系列で表示。タグ・タイプ・ソースで絞り込めます。</p>
    <div class="entries-header">
      <p class="entry-count">{entries.length} 件</p>
      <div class="sort-controls">
        <button class="sort-btn active" data-sort="date" data-order="desc">{t('sort.postDate')} ↓</button>
        {hasGitDates && (
          <>
            <button class="sort-btn" data-sort="created" data-order="desc">{t('sort.added')} ↓</button>
            <button class="sort-btn" data-sort="updated" data-order="desc">{t('sort.updated')} ↓</button>
          </>
        )}
      </div>
    </div>
    <div id="entries-list">
      {displayEntries.map((entry: any) => {
        const tid = resolveThreadId(entry);
        const msgCount = tid ? threadCounts.get(tid) || 0 : 0;
        const isThread = msgCount >= 2;
        const gd = gitDates[entry.id];
        return (
          <EntryCard
            id={entry.id}
            title={isThread ? threadTitles.get(tid!) || entry.data.title : entry.data.title}
            date={entry.data.date}
            author={entry.data.author}
            source={entry.data.source}
            description={entry.data.description}
            isSatoshi={entry.data.isSatoshi}
            lang={lang}
            threadId={isThread ? tid : undefined}
            threadCount={isThread ? msgCount : undefined}
            participants={entry.data.participants}
            entryType={entry.data.type}
            createdAt={gd?.createdAt}
            updatedAt={gd?.updatedAt}
          />
        );
      })}
    </div>
  </div>
</BaseLayout>

<script is:inline>
(function() {
  var STORAGE_KEY = 'entries-sort';
  var list = document.getElementById('entries-list');
  var btns = document.querySelectorAll('.sort-btn');
  if (!list || !btns.length) return;

  function getLabel(btn) {
    return btn.textContent.replace(/\s*[↑↓]$/, '');
  }

  function applySort(key, order) {
    var cards = Array.from(list.querySelectorAll('.entry-card'));
    cards.sort(function(a, b) {
      var av, bv;
      if (key === 'date') { av = a.dataset.date || ''; bv = b.dataset.date || ''; }
      else if (key === 'created') { av = a.dataset.created || ''; bv = b.dataset.created || ''; }
      else { av = a.dataset.updated || ''; bv = b.dataset.updated || ''; }
      return order === 'asc' ? av.localeCompare(bv) : bv.localeCompare(av);
    });
    cards.forEach(function(card) { list.appendChild(card); });
  }

  function activateBtn(key, order) {
    btns.forEach(function(b) { b.classList.remove('active'); });
    btns.forEach(function(b) {
      if (b.dataset.sort === key) {
        b.classList.add('active');
        b.dataset.order = order;
        b.textContent = getLabel(b) + (order === 'asc' ? ' ↑' : ' ↓');
      }
    });
  }

  // Restore saved sort
  try {
    var saved = JSON.parse(sessionStorage.getItem(STORAGE_KEY));
    if (saved && saved.key) {
      activateBtn(saved.key, saved.order);
      applySort(saved.key, saved.order);
    }
  } catch(e) {}

  btns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var key = btn.dataset.sort;
      var order = btn.dataset.order;
      var isActive = btn.classList.contains('active');

      if (isActive) {
        order = order === 'asc' ? 'desc' : 'asc';
        btn.dataset.order = order;
      } else {
        btns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
      }

      btn.textContent = getLabel(btn) + (order === 'asc' ? ' ↑' : ' ↓');
      applySort(key, order);

      try { sessionStorage.setItem(STORAGE_KEY, JSON.stringify({key: key, order: order})); } catch(e) {}
    });
  });
})();
</script>

<style>
  h1 { margin-bottom: 0.25rem; }
  .page-lead {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0 0 0.75rem 0;
    max-width: var(--max-width-prose);
  }
  .entries-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  .entry-count {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
  }
  .sort-controls {
    display: flex;
    gap: 0.25rem;
    font-family: var(--font-heading);
    font-size: 0.8rem;
  }
  .sort-btn {
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    padding: 0.2em 0.6em;
    color: var(--color-text-muted);
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
  }
  .sort-btn:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }
  .sort-btn.active {
    color: var(--color-text);
    font-weight: 600;
    border-color: var(--color-text);
  }
</style>
