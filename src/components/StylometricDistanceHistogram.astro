---
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const data = await import('../data/derived/van-dorst-burrows-distribution.json').then(m => m.default);

// Stats summary text is derived from the JSON's stats block at render time
// so it stays in sync with the data when the corpus is regenerated. The only
// hardcoded number left is the methodology constant ">= 10 chunks", which is
// the filter applied during extraction (not a derived statistic).
const s = data.stats;
const totalAuthorsEN = s.totalAuthors.toLocaleString('en-US');
const totalAuthorsJA = s.totalAuthors.toLocaleString('ja-JP');
const meanStr = s.mean.toFixed(5);
const stdevStr = s.stdev.toFixed(5);
const minStr = s.min.toFixed(5);
const maxStr = s.max.toFixed(5);

const labels = {
  en: {
    title: `Burrows' Delta distribution: Satoshi vs. ${totalAuthorsEN} mailing-list authors (van Dorst 2024)`,
    subtitle: "Each bar is the count of mailing-list-active authors (≥10 chunks of writing) in that Burrows' Delta range. Lower delta = closer match to Satoshi's reference profile. The most-cited Satoshi-identity named candidates are marked with colored horizontal lines. Corpus mean line shown for reference.",
    xLabel: 'Authors per bin',
    yLabel: "Burrows' Delta to Satoshi (lower = closer, top = closest)",
    meanLabel: 'Corpus mean',
    medianLabel: 'Corpus median',
    namedLabel: 'Named candidates',
    directionLabel: '↑ Closer to Satoshi',
    tooltipBin: 'Bin',
    tooltipCount: 'Authors',
    tooltipBurrow: 'Burrows Δ',
    tooltipRank: 'Rank',
    tooltipChunks: 'chunks',
    statsLine: `Corpus: ${totalAuthorsEN} authors with ≥10 chunks · mean ${meanStr} · σ ${stdevStr} · range [${minStr}, ${maxStr}]`,
    insightHeading: 'What this shows',
    insight1: 'All named candidates fall in the upper (top-side) tail of the distribution — closer to Satoshi than the corpus mean.',
    insight2: 'Nick Szabo at top 4.67% leads the named-candidate group; Hal Finney (6.89%) and Adam Back (7.87%) follow closely.',
    insight3: 'But 594 authors rank closer than Szabo. Most of those upper-tail authors are noise (e-commerce accounts, anonymous remailers, disposable accounts), not viable candidates — see the §3 noise-tail discussion below.',
    candidateNames: {
      'Nick Szabo': 'Nick Szabo',
      'Hal Finney': 'Hal Finney',
      'Adam Back': 'Adam Back',
      'Wei Dai': 'Wei Dai',
      'Len Sassaman': 'Len Sassaman',
    } as Record<string, string>,
  },
  ja: {
    title: `バローズ・デルタ分布：サトシ vs メーリングリスト書き手 ${totalAuthorsJA} 名（ヴァン・ドルスト 2024）`,
    subtitle: '各バーは、そのバローズ・デルタ範囲に位置するメーリングリスト活動書き手（10 チャンク以上）の数。デルタが低いほどサトシ参照プロファイルに近い。最も多く引用されるサトシ正体候補を色付き水平線で示す。コーパス平均も参考表示。',
    xLabel: 'バーごとの著者数',
    yLabel: 'サトシへのバローズ・デルタ（低いほど近い、上方ほど近い）',
    meanLabel: 'コーパス平均',
    medianLabel: 'コーパス中央値',
    namedLabel: '名指し候補',
    directionLabel: '↑ サトシに近い',
    tooltipBin: '区間',
    tooltipCount: '著者数',
    tooltipBurrow: 'バローズ Δ',
    tooltipRank: '順位',
    tooltipChunks: 'チャンク',
    statsLine: `コーパス：10 チャンク以上の著者 ${totalAuthorsJA} 名／平均 ${meanStr}／σ ${stdevStr}／範囲 [${minStr}, ${maxStr}]`,
    insightHeading: 'この図が示すもの',
    insight1: '名指し候補はすべて分布の上方（サトシ側）に位置 — コーパス平均よりサトシに近い。',
    insight2: 'ニック・サボが上位 4.67% で名指し集団の首位。ハル・フィニー（6.89%）、アダム・バック（7.87%）が僅差で続く。',
    insight3: 'ただしサボより近い著者が 594 人いる。その上位陣の大半はノイズ（EC アカウント、匿名リメイラー、使い捨てアカウント）であって妥当な候補ではない — §3 のノイズ層議論を参照。',
    candidateNames: {
      'Nick Szabo': 'ニック・サボ',
      'Hal Finney': 'ハル・フィニー',
      'Adam Back': 'アダム・バック',
      'Wei Dai': 'ウェイ・ダイ',
      'Len Sassaman': 'レン・サッサマン',
    } as Record<string, string>,
  },
};

// @ts-ignore — lang is 'en' | 'ja' but TS may not infer correctly through Astro.props
const l = labels[lang as 'en' | 'ja'] || labels.en;

// Color per candidate
const candidateColors: Record<string, string> = {
  'Nick Szabo': '#dc2626',     // red — leads named group
  'Hal Finney': '#ea580c',     // orange
  'Adam Back': '#ca8a04',      // gold
  'Wei Dai': '#16a34a',        // green
  'Len Sassaman': '#2563eb',   // blue
};
---

<div class="stylometric-histogram analysis-section">
  <section>
    <h3>{l.title}</h3>
    <p class="analysis-desc">{l.subtitle}</p>

    <div id="stylometric-hist-chart" class="chart-container" style="width:100%; min-height:400px;"></div>

    <p class="stats-line">{l.statsLine}</p>

    <div class="insight">
      <strong>{l.insightHeading}:</strong>
      <ul>
        <li>{l.insight1}</li>
        <li>{l.insight2}</li>
        <li>{l.insight3}</li>
      </ul>
    </div>
  </section>

  <script type="application/json" id="stylometric-hist-data" set:html={JSON.stringify({
    bins: data.bins,
    stats: data.stats,
    namedCandidates: data.namedCandidates,
    candidateColors,
    labels: l,
  })} />
  <script is:inline src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js"></script>
</div>

<script is:inline>
(function() {
  function init() {
    if (typeof d3 === 'undefined') { setTimeout(init, 50); return; }
    var dataEl = document.getElementById('stylometric-hist-data');
    if (!dataEl) return;
    var data = JSON.parse(dataEl.textContent);
    var bins = data.bins;
    var stats = data.stats;
    // Dedupe named candidates by label for chart display: when one author has
    // multiple email accounts in the corpus (e.g. Adam Back: adam@cypherspace
    // and aba@dcs.ex.ac.uk), the chart shows only the closest-to-Satoshi
    // account (lowest Burrows Δ). The detailed per-account breakdown lives in
    // the entry's table — the chart's job is to place the named candidates
    // visually in the distribution, where one row per author is clearer.
    var named = (function dedupe(list) {
      var byLabel = {};
      list.forEach(function(c) {
        var prev = byLabel[c.label];
        if (!prev || c.burrow < prev.burrow) byLabel[c.label] = c;
      });
      return Object.keys(byLabel).map(function(k) { return byLabel[k]; });
    })(data.namedCandidates);
    var colors = data.candidateColors;
    var l = data.labels;

    var container = document.getElementById('stylometric-hist-chart');
    if (!container) return;
    container.style.position = 'relative';

    function draw() {
      container.innerHTML = '';
      var rect = container.getBoundingClientRect();
      var W = rect.width || 700;
      // Horizontal-bar layout: Y axis is Burrows Delta (top = lowest = closest
      // to Satoshi), X axis is author count. Wide left margin holds candidate
      // labels; vertical stagger with leader lines bridges the cluster.
      // Margin left budget:
      //   ~210px = candidate label area (~150px) + leader line space (~25px)
      //          + Y-axis tick numbers (~35px). No rotated Y-axis label —
      //          the description above the chart already explains the axis.
      var margin = { top: 28, right: 24, bottom: 46, left: 200 };
      var H = Math.min(640, Math.max(480, W * 0.65));
      var w = W - margin.left - margin.right;
      var h = H - margin.top - margin.bottom;

      var svg = d3.select(container).append('svg')
        .attr('width', W).attr('height', H)
        .attr('viewBox', '0 0 ' + W + ' ' + H);

      var g = svg.append('g').attr('transform', 'translate(' + margin.left + ',' + margin.top + ')');

      // Y domain zoomed to mean ± 2.5σ — outside that range bins are nearly
      // empty (the corpus tails extend to ~12σ on the low side from outliers
      // but contain almost no authors). Top of chart = lowest delta = closest
      // to Satoshi. Named candidates span 0.14405-0.14428 (mean − 1.9σ to
      // mean − 1.0σ), all comfortably inside the zoomed range.
      var yMin = stats.mean - 2.5 * stats.stdev;
      var yMax = stats.mean + 2.5 * stats.stdev;
      var y = d3.scaleLinear()
        .domain([yMin, yMax])
        .range([0, h]);

      // Filter out bins whose Δ range falls entirely outside [yMin, yMax].
      // Without this, far-tail bins still render but get clipped to y < 0 or
      // y > h, leaving stray slivers that visually collide with the X axis.
      var visibleBins = bins.filter(function(b) {
        return b.x1 > yMin && b.x0 < yMax;
      });

      var maxCount = d3.max(visibleBins, function(b) { return b.count; });
      var x = d3.scaleLinear()
        .domain([0, maxCount * 1.1])
        .range([0, w]);

      // Horizontal bars: each bin is a rect spanning from x=0 to x(count),
      // vertically positioned at y(bin.x0)..y(bin.x1). Clamp the bin's Δ
      // edges to [yMin, yMax] so bins straddling the visible boundary stop
      // exactly at the chart edge instead of leaking into the X-axis area.
      g.selectAll('.bar')
        .data(visibleBins)
        .enter().append('rect')
        .attr('class', 'bar')
        .attr('x', 0)
        .attr('y', function(d) { return y(Math.max(yMin, d.x0)); })
        .attr('width', function(d) { return x(d.count); })
        .attr('height', function(d) {
          var top = y(Math.max(yMin, d.x0));
          var bot = y(Math.min(yMax, d.x1));
          return Math.max(0, bot - top - 1);
        })
        .attr('fill', '#94a3b8')
        .attr('opacity', 0.7);

      // Direction annotation in the top-left margin: "↑ Closer to Satoshi".
      // Sits just above the chart in the top margin so it doesn't overlap the
      // first bar. Positioned at x=2 (chart left edge) so it reads alongside
      // the Y axis. It tells the reader at a glance that "up = closer to
      // Satoshi", which the bar layout alone doesn't convey.
      g.append('text')
        .attr('x', 2).attr('y', -10)
        .attr('text-anchor', 'start').attr('fill', '#475569').attr('font-size', '11px')
        .attr('font-weight', '600')
        .text(l.directionLabel);

      // Corpus mean: horizontal dashed line spanning the whole chart width.
      var meanY = y(stats.mean);
      g.append('line')
        .attr('y1', meanY).attr('y2', meanY)
        .attr('x1', 0).attr('x2', w)
        .attr('stroke', '#475569').attr('stroke-width', 1).attr('stroke-dasharray', '4 3');

      g.append('text')
        .attr('x', w - 4).attr('y', meanY - 4)
        .attr('text-anchor', 'end').attr('fill', '#475569').attr('font-size', '11px')
        .text(l.meanLabel + ' ' + stats.mean.toFixed(5));

      // Named candidate horizontal lines.
      // For label placement, sort candidates by Y position, then evenly
      // distribute label slots around the cluster center to avoid overlap.
      // Each label shows: name + percentile. A leader line connects from the
      // candidate's actual Y on chart to the staggered label Y in the left
      // margin.
      var sorted = named.slice().sort(function(a, b) { return a.burrow - b.burrow; });
      var minLabelGap = 22;
      var clusterCenterY = sorted.reduce(function(s, c) { return s + y(c.burrow); }, 0) / sorted.length;
      var totalSpan = (sorted.length - 1) * minLabelGap;
      var firstLabelY = clusterCenterY - totalSpan / 2;
      // Clamp into chart vertical area
      if (firstLabelY < 8) firstLabelY = 8;
      if (firstLabelY + totalSpan > h - 8) firstLabelY = h - 8 - totalSpan;

      sorted.forEach(function(c, i) {
        c._cy = y(c.burrow);
        c._labelY = firstLabelY + i * minLabelGap;
      });

      // Candidate horizontal lines (drawn first, behind labels).
      sorted.forEach(function(c) {
        var color = colors[c.label] || '#666';
        g.append('line')
          .attr('y1', c._cy).attr('y2', c._cy)
          .attr('x1', 0).attr('x2', w)
          .attr('stroke', color).attr('stroke-width', 1.5)
          .attr('opacity', 0.7);

        // Triangle marker pointing right, at left edge of plot area
        g.append('path')
          .attr('d', 'M0,' + c._cy + ' L-7,' + (c._cy - 5) + ' L-7,' + (c._cy + 5) + ' Z')
          .attr('fill', color);
      });

      // Labels in left margin. No leader lines — each candidate's horizontal
      // line on the chart is drawn in the candidate's color, and the label
      // text uses the same color, so the reader matches by color directly.
      // Labels are RIGHT-aligned (text-anchor='end') so all label right edges
      // line up neatly near labelRightX. labelRightX is placed left of the
      // Y-axis tick numbers (which sit at x ≈ -9 with text-anchor='end',
      // extending leftward to roughly x=-45) so the two layers don't overlap.
      var labelRightX = -52;
      sorted.forEach(function(c) {
        var color = colors[c.label] || '#666';
        var displayName = (l.candidateNames && l.candidateNames[c.label]) || c.label;
        var labelText = displayName + ' (' + c.percentile + '%)';

        g.append('text')
          .attr('x', labelRightX).attr('y', c._labelY)
          .attr('text-anchor', 'end')
          .attr('fill', color).attr('font-size', '11px').attr('font-weight', '600')
          .text(labelText);
      });

      // Y axis (tick numbers only, no rotated axis label — the chart
      // description above explains the axis).
      g.append('g').attr('class', 'axis y')
        .call(d3.axisLeft(y).ticks(6).tickFormat(function(d) { return d.toFixed(4); }));

      // X axis
      g.append('g').attr('class', 'axis x')
        .attr('transform', 'translate(0,' + h + ')')
        .call(d3.axisBottom(x).ticks(6));

      // X label
      svg.append('text')
        .attr('x', margin.left + w / 2).attr('y', H - 8)
        .attr('text-anchor', 'middle').attr('font-size', '12px').attr('fill', '#475569')
        .text(l.xLabel);

      // Tooltip on bars (still useful for hovering specific bins)
      var tooltip = d3.select(container).append('div')
        .style('position', 'absolute').style('pointer-events', 'none').style('opacity', 0)
        .style('background', 'rgba(0,0,0,0.88)').style('color', '#fff')
        .style('padding', '7px 10px').style('border-radius', '4px')
        .style('font-size', '12px').style('white-space', 'nowrap').style('z-index', '10');

      g.selectAll('.bar')
        .on('mousemove', function(event, d) {
          tooltip.html(
            '<b>' + l.tooltipBin + ': ' + d.x0.toFixed(5) + '–' + d.x1.toFixed(5) + '</b><br>' +
            l.tooltipCount + ': ' + d.count
          ).style('opacity', 1);
          var cr = container.getBoundingClientRect();
          var tx = event.clientX - cr.left + 14;
          var ty = event.clientY - cr.top - 10;
          if (tx + 200 > cr.width) tx = tx - 220;
          tooltip.style('left', tx + 'px').style('top', ty + 'px');
        })
        .on('mouseleave', function() { tooltip.style('opacity', 0); });
    }

    draw();
    var timer;
    window.addEventListener('resize', function() { clearTimeout(timer); timer = setTimeout(draw, 200); });
  }
  init();
})();
</script>

<style>
  .stylometric-histogram {
    margin: 2rem 0;
  }
  .analysis-section h3 {
    font-size: 1.1rem;
    margin-bottom: 0.4rem;
  }
  .analysis-desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    margin-top: 0;
    margin-bottom: 1rem;
  }
  .chart-container {
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-bg);
    overflow: hidden;
    padding: 0.5rem;
  }
  .chart-container :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }
  .chart-container :global(.axis path),
  .chart-container :global(.axis line) {
    stroke: #cbd5e1;
  }
  .chart-container :global(.axis text) {
    fill: #475569;
    font-size: 10px;
  }
  .stats-line {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    margin: 0.5rem 0 0.6rem;
    text-align: center;
  }
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 1.1rem;
    margin: 0.75rem 0;
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .legend-line {
    display: inline-block;
    width: 18px;
    height: 3px;
    border-radius: 1px;
  }
  .legend-mean {
    background: #475569;
    background-image: linear-gradient(to right, #475569 4px, transparent 4px, transparent 7px, #475569 7px);
    background-size: 7px 100%;
  }
  .insight {
    margin-top: 1rem;
    padding: 0.75rem 1rem;
    background: var(--color-bg-subtle, #f8fafc);
    border-left: 3px solid #2563eb;
    border-radius: 0 4px 4px 0;
    font-size: 0.88rem;
  }
  .insight ul {
    margin: 0.4rem 0 0;
    padding-left: 1.2rem;
  }
  .insight li {
    margin-bottom: 0.3rem;
  }
</style>
