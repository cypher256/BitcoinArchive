---
import LanguageSwitch from './LanguageSwitch.astro';
import { useTranslations, localePath } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<header class="site-header">
  <div class="container-wide header-inner">
    <a href={localePath('/', lang)} class="site-title">
      <strong>{t('site.title')}</strong>
    </a>
    <button
      type="button"
      class="mobile-menu-toggle"
      aria-expanded="false"
      aria-controls="site-nav"
      aria-label={t('nav.menu' as any)}
    >
      <span class="menu-icon menu-icon-open" aria-hidden="true">☰</span>
      <span class="menu-icon menu-icon-close" aria-hidden="true">✕</span>
    </button>
    <nav class="main-nav" id="site-nav">
      <a href={localePath('/entries/', lang)}>{t('nav.entries')}</a>
      <details class="nav-dropdown">
        <summary>{t('nav.browse' as any)}<span class="chevron" aria-hidden="true">▾</span></summary>
        <div class="nav-dropdown-menu">
          <a href={localePath('/types/', lang)}>{t('nav.types' as any)}</a>
          <a href={localePath('/sources/', lang)}>{t('nav.sources')}</a>
          <a href={localePath('/participants/', lang)}>{t('nav.participants')}</a>
          <a href={localePath('/tags/', lang)}>{t('nav.tags')}</a>
        </div>
      </details>
      <a href={localePath('/about/', lang)}>{t('nav.about')}</a>
      <a href={localePath('/search/', lang)}>{t('nav.search')}</a>
      <LanguageSwitch lang={lang} />
      {/*
        3-way mode toggle (light → dark → system → light …).
        - State lives on `localStorage.mode` ('light' | 'dark' | absent).
        - <html data-mode> mirrors the state; absence = follow OS.
        - The icon is rotated by the script to match the active state.
        - aria-label is updated dynamically to announce the next state.
        Initial state is set in the head-earliest script in BaseLayout
        so the button label is correct on first paint; the markup
        below is the static fallback.
      */}
      <button
        type="button"
        class="mode-toggle"
        data-mode-toggle
        aria-label="Toggle color mode"
        title="Toggle light / dark / system"
      >
        <svg class="mode-icon mode-icon-light" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
        </svg>
        <svg class="mode-icon mode-icon-dark" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
        <svg class="mode-icon mode-icon-system" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="3" width="20" height="14" rx="2" />
          <path d="M8 21h8M12 17v4" />
        </svg>
      </button>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
    gap: 1rem;
  }
  .site-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
  }
  .site-title:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
  .main-nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    font-family: var(--font-heading);
    font-size: 0.9rem;
  }
  .main-nav > a {
    color: var(--color-text-muted);
    text-decoration: none;
    white-space: nowrap;
  }
  .main-nav > a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  /* Browse ドロップダウン */
  .nav-dropdown {
    position: relative;
  }
  .nav-dropdown > summary {
    color: var(--color-text-muted);
    cursor: pointer;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    list-style: none; /* Firefox, Chrome 等の一般ブラウザ */
  }
  /* Safari / 旧Chrome */
  .nav-dropdown > summary::-webkit-details-marker {
    display: none;
  }
  /* モダンブラウザの ::marker（Safari 18+ 等） */
  .nav-dropdown > summary::marker {
    content: '';
  }
  .nav-dropdown > summary:hover {
    color: var(--color-text);
  }
  .nav-dropdown .chevron {
    font-size: 0.7em;
    transition: transform 0.15s;
  }
  .nav-dropdown[open] > summary {
    color: var(--color-text);
  }
  .nav-dropdown[open] .chevron {
    transform: rotate(180deg);
  }
  .nav-dropdown-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    min-width: 180px;
    padding: 0.4rem 0;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    z-index: 101;
  }
  .nav-dropdown-menu a {
    display: block;
    padding: 0.5rem 1rem;
    color: var(--color-text-muted);
    text-decoration: none;
    white-space: nowrap;
  }
  .nav-dropdown-menu a:hover {
    background: rgba(0, 0, 0, 0.04);
    color: var(--color-text);
    text-decoration: none;
  }

  /* 3-way 配色モード切替ボタン (light / dark / system) */
  .mode-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.3rem 0.4rem;
    line-height: 0;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }
  .mode-toggle:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .mode-toggle:focus-visible {
    outline: 2px solid var(--color-link);
    outline-offset: 2px;
  }
  .mode-icon {
    display: none;
  }
  /* default (no localStorage / no data-mode) = system */
  .mode-toggle .mode-icon-system {
    display: inline;
  }
  :global(:root[data-mode="light"]) .mode-toggle .mode-icon-light {
    display: inline;
  }
  :global(:root[data-mode="light"]) .mode-toggle .mode-icon-system,
  :global(:root[data-mode="light"]) .mode-toggle .mode-icon-dark {
    display: none;
  }
  :global(:root[data-mode="dark"]) .mode-toggle .mode-icon-dark {
    display: inline;
  }
  :global(:root[data-mode="dark"]) .mode-toggle .mode-icon-system,
  :global(:root[data-mode="dark"]) .mode-toggle .mode-icon-light {
    display: none;
  }

  /* ハンバーガーボタン（デスクトップでは非表示） */
  .mobile-menu-toggle {
    display: none;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.3rem 0.55rem;
    font-size: 1.15rem;
    line-height: 1;
    color: var(--color-text);
    cursor: pointer;
  }
  .mobile-menu-toggle:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .mobile-menu-toggle .menu-icon-close {
    display: none;
  }
  .mobile-menu-toggle[aria-expanded="true"] .menu-icon-open {
    display: none;
  }
  .mobile-menu-toggle[aria-expanded="true"] .menu-icon-close {
    display: inline;
  }

  @media (max-width: 768px) {
    .header-inner {
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem;
    }
    .mobile-menu-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    /* モバイルではナビを畳む（ハンバーガーで開閉） */
    .main-nav {
      display: none;
      flex-basis: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0.25rem;
      padding: 0.75rem 0 0.25rem;
      margin-top: 0.5rem;
      border-top: 1px solid var(--color-border);
      font-size: 0.95rem;
    }
    .main-nav.is-open {
      display: flex;
    }
    .main-nav > a,
    .nav-dropdown > summary {
      padding: 0.55rem 0.25rem;
      border-radius: 4px;
    }
    .main-nav > a:hover,
    .nav-dropdown > summary:hover {
      background: rgba(0, 0, 0, 0.04);
    }
    /* モバイル時 Browse dropdown はインライン展開（overlay でなく縦に追加） */
    .nav-dropdown-menu {
      position: static;
      min-width: auto;
      margin: 0.25rem 0 0.25rem 1rem;
      padding: 0.15rem 0;
      background: transparent;
      border: none;
      box-shadow: none;
      flex-direction: column;
      gap: 0;
    }
    .nav-dropdown-menu a {
      padding: 0.4rem 0.5rem;
      border-radius: 4px;
    }
  }
</style>

<script is:inline>
(function() {
  // 配色モード 3-way 切替: light → dark → system → light …
  // 状態は localStorage.mode に保存。null = system (OS 設定追従)
  var modeBtn = document.querySelector('[data-mode-toggle]');
  if (modeBtn) {
    function modeLabel(state) {
      // state は次に遷移する状態を表す aria-label として読まれる
      if (state === 'light') return 'Switch to dark mode';
      if (state === 'dark') return 'Switch to system mode';
      return 'Switch to light mode';
    }
    function readMode() {
      try { return localStorage.getItem('mode'); } catch (_) { return null; }
    }
    function refreshLabel() {
      var cur = readMode();
      var next = cur === 'light' ? 'dark' : cur === 'dark' ? null : 'light';
      modeBtn.setAttribute('aria-label', modeLabel(next));
    }
    refreshLabel();
    modeBtn.addEventListener('click', function () {
      var cur = readMode();
      var next = cur === 'light' ? 'dark' : cur === 'dark' ? null : 'light';
      try {
        if (next) {
          localStorage.setItem('mode', next);
          document.documentElement.setAttribute('data-mode', next);
        } else {
          localStorage.removeItem('mode');
          document.documentElement.removeAttribute('data-mode');
        }
      } catch (_) {
        // localStorage が使えない環境では attribute だけ更新する
        if (next) document.documentElement.setAttribute('data-mode', next);
        else document.documentElement.removeAttribute('data-mode');
      }
      refreshLabel();
    });
  }

  // ハンバーガー: モバイルメニュー開閉
  var toggle = document.querySelector('.mobile-menu-toggle');
  var nav = document.getElementById('site-nav');
  if (toggle && nav) {
    toggle.addEventListener('click', function() {
      var isOpen = nav.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });
  }

  // Browse ドロップダウン: クリック外で閉じる
  document.addEventListener('click', function(e) {
    document.querySelectorAll('details.nav-dropdown[open]').forEach(function(d) {
      if (!d.contains(e.target)) d.removeAttribute('open');
    });
  });

  // ESC: Browse ドロップダウン → モバイルメニューの順に閉じる
  document.addEventListener('keydown', function(e) {
    if (e.key !== 'Escape') return;
    var openDropdown = document.querySelector('details.nav-dropdown[open]');
    if (openDropdown) {
      openDropdown.removeAttribute('open');
      var summary = openDropdown.querySelector('summary');
      if (summary) summary.focus();
      return;
    }
    if (nav && nav.classList.contains('is-open')) {
      nav.classList.remove('is-open');
      if (toggle) {
        toggle.setAttribute('aria-expanded', 'false');
        toggle.focus();
      }
    }
  });
})();
</script>
