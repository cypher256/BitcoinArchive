---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NetworkGraph from '../../components/NetworkGraph.astro';
import { useTranslations, getDisplayEntries, localePath } from '../../i18n/utils';
import { computeGraphData } from '../../lib/graphData';

const lang = 'en';
const t = useTranslations(lang);
const entries = await getDisplayEntries(lang);
const graphData = computeGraphData(entries);
---

<BaseLayout
  title={`${t('network.title' as any)} - ${t('site.title')}`}
  description={t('network.description' as any)}
  lang={lang}
  alternateJa="https://cypher256.github.io/BitcoinArchive/ja/participants/network/"
>
  <div class="container-wide">
    <nav class="back-nav">
      <a href={localePath('/participants/', lang)}>&larr; {t('nav.participants')}</a>
    </nav>
    <h1>{t('network.title' as any)}</h1>
    <p class="page-description">{t('network.description' as any)}</p>
    <NetworkGraph graphData={graphData} lang={lang} />
  </div>
</BaseLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js"></script>

<style>
  .back-nav {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }
  h1 {
    margin-bottom: 0.25rem;
  }
  .page-description {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }
</style>
